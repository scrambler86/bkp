function Normalize-Config($cfg) {
    $def = Get-DefaultConfig

    foreach ($p in $def.PSObject.Properties.Name) {
        if ($cfg.PSObject.Properties.Match($p).Count -eq 0 -or $null -eq $cfg.$p) {
            Set-OrAddProp $cfg $p $def.$p
        }
    }

    Ensure-SubObject $cfg 'Email'  $def.Email
    Ensure-SubObject $cfg 'Discord' $def.Discord
    Ensure-SubObject $cfg 'Tasks'  $def.Tasks

    foreach ($p in $def.Email.PSObject.Properties.Name) {
        if ($cfg.Email.PSObject.Properties.Match($p).Count -eq 0 -or $null -eq $cfg.Email.$p) {
            Set-OrAddProp $cfg.Email $p $def.Email.$p
        }
    }

    foreach ($p in $def.Discord.PSObject.Properties.Name) {
        if ($cfg.Discord.PSObject.Properties.Match($p).Count -eq 0 -or $null -eq $cfg.Discord.$p) {
            Set-OrAddProp $cfg.Discord $p $def.Discord.$p
        }
    }

    foreach ($p in $def.Tasks.PSObject.Properties.Name) {
        if ($cfg.Tasks.PSObject.Properties.Match($p).Count -eq 0 -or $null -eq $cfg.Tasks.$p) {
            Set-OrAddProp $cfg.Tasks $p $def.Tasks.$p
        }
    }

    foreach ($propName in @('SuccessMessagePatterns','FailureMessagePatterns','IgnoreMessagePatterns')) {
        $defList = @($def.$propName)
        if ($null -eq $cfg.$propName -or @($cfg.$propName).Count -eq 0) {
            $cfg.$propName = @($defList)
        } else {
            $cfg.$propName = @($cfg.$propName | ForEach-Object { [string]$_ } | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })
            if (@($cfg.$propName).Count -eq 0) {
                $cfg.$propName = @($defList)
            }
        }
    }

    $cfg.DailyCheckTime = Normalize-ScheduleTimeLoose $cfg.DailyCheckTime '09:30'

    $cfg.ScheduleFrequency = ([string]$cfg.ScheduleFrequency).Trim()
    if ($cfg.ScheduleFrequency -notin @('Daily','Weekly','Monthly')) { $cfg.ScheduleFrequency = 'Daily' }

    # BackupMode: normalizza e applica vincoli
    $cfg.BackupMode = Normalize-BackupMode ([string]$cfg.BackupMode)
    switch ($cfg.BackupMode) {
        'FileHistory' { $cfg.MonitorFileHistory = $true }
        'WSB'         { $cfg.MonitorFileHistory = $false }
        'Legacy'      { $cfg.MonitorFileHistory = $false }
        default       { }
    }

 # [BOOKMARK:FH_RULES]
    # Modalità FileHistory: su config vecchie può mancare la lista ID/pattern di File History.
    # Se mancano, gli eventi (es. EventID 201) restano UNKNOWN e NON notificano.
    $useFH = ($cfg.BackupMode -eq 'FileHistory') -or ($cfg.BackupMode -eq 'Auto' -and [bool]$cfg.MonitorFileHistory)
    if ($useFH) {
        # EventID File History (Win8/10/11): 200=FAIL (ambiguo), 201/202/203/204=FAIL
        $cfg.SuccessEventIds = @($cfg.SuccessEventIds | Where-Object { $_ -ne 200 })
        $cfg.FailureEventIds = Ensure-IntListContains $cfg.FailureEventIds @(200,201,202,203,204)

        # Pattern minimi (match su messaggio) per coprire casi dove l'ID non basta o differisce
        $cfg.SuccessMessagePatterns = Ensure-StringListContains $cfg.SuccessMessagePatterns @(
            'backup cycle completed',
            'ciclo di backup completato'
        )
        $cfg.FailureMessagePatterns = Ensure-StringListContains $cfg.FailureMessagePatterns @(
            'impossibile cercare le modifiche nelle librerie dell''utente',
            'impossibile cercare le modifiche nelle librerie',
            'unable to scan user libraries',
            'unusual condition was encountered',
            'impossibile avviare un ciclo di backup',
            'unable to start a backup cycle',
            'impossibile completare un ciclo di backup',
            'condizione anomala'
        )
        $cfg.IgnoreMessagePatterns = Ensure-StringListContains $cfg.IgnoreMessagePatterns @(
            'backup del file non eseguito',
            'un nuovo tentativo di backup verrà eseguito'
        )
    }

    $cfg.Tasks.EventTaskName = "Monitor_Backup_$($cfg.BackupName)_EVENT"
    $cfg.Tasks.DailyTaskName = "Monitor_Backup_$($cfg.BackupName)_DAILY"
    return $cfg
}

function Save-Config($cfg) {
    try {
        Ensure-Dir $ConfigDir
        $cfg | ConvertTo-Json -Depth 12 | Set-Content -Path $ConfigPath -Encoding UTF8 -Force
        return
    } catch {
        # Fallback LocalAppData: emette warning esplicito -- i task SYSTEM non vedranno questa config.
        if ($ConfigDir -ne $ConfigDirFallback -and (Test-WriteAccess $ConfigDirFallback)) {
            $script:ConfigDir     = $ConfigDirFallback
            $script:ConfigPath    = Join-Path $script:ConfigDir 'config.json'
            $script:SecretKeyPath = Join-Path $script:ConfigDir 'secret.key'
            $script:RuntimeStatePath = Join-Path $script:ConfigDir 'runtime_state.json'
            Ensure-Dir $ConfigDir
            $cfg | ConvertTo-Json -Depth 12 | Set-Content -Path $ConfigPath -Encoding UTF8 -Force
            Write-Warning "Config salvata in LocalAppData (ProgramData non scrivibile). I task SYSTEM non troveranno questa configurazione."
            return
        }
        throw
    }
}
function Load-Config {
    Ensure-Dir $ConfigDir

    if (-not (Test-Path $ConfigPath)) {
        return (Normalize-Config (Get-DefaultConfig))
    }

    $raw = Get-Content $ConfigPath -Raw -Encoding UTF8
    if ([string]::IsNullOrWhiteSpace($raw)) {
        throw "Config vuoto: $ConfigPath"
    }

    try {
        $cfg = $raw | ConvertFrom-Json -ErrorAction Stop
    } catch {
        throw "Errore parsing JSON config ($ConfigPath): $($_.Exception.Message)"
    }

    try {
        return (Normalize-Config $cfg)
    } catch {
        throw "Errore normalizzazione config ($ConfigPath): $($_.Exception.Message)"
    }
}

function Safe-Int([object]$v, [int]$fallback) { try { return [int]$v } catch { return $fallback } }



# [BOOKMARK:LIST_UTILS]
# Utility per aggiornare config vecchie senza perdere impostazioni esistenti.
function Ensure-IntListContains([object]$list, [int[]]$mustHave) {
    $arr = @()
    if ($null -ne $list) {
        $arr = @($list | ForEach-Object { Safe-Int $_ 0 } | Where-Object { $_ -ne 0 })
    }
    foreach ($i in @($mustHave)) {
        if ($i -gt 0 -and ($arr -notcontains $i)) { $arr += $i }
    }
    return $arr
}

function Ensure-StringListContains([object]$list, [string[]]$mustHave) {
    $arr = @()
    if ($null -ne $list) {
        $arr = @($list | ForEach-Object { [string]$_ } | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })
    }
    $lower = @($arr | ForEach-Object { $_.ToLowerInvariant() })
    foreach ($s in @($mustHave)) {
        $ss = ([string]$s)
        if ([string]::IsNullOrWhiteSpace($ss)) { continue }
        $ssl = $ss.ToLowerInvariant()
        if ($lower -notcontains $ssl) {
            $arr += $ss
            $lower += $ssl
        }
    }
    return $arr
}

function Test-EventLogExists([string]$logName) {
    if ([string]::IsNullOrWhiteSpace($logName)) { return $false }

    try {
        [void](Get-WinEvent -ListLog $logName -ErrorAction Stop)
        return $true
    } catch {
        try {
            $null = & wevtutil.exe gli "$logName" 2>$null
            return ($LASTEXITCODE -eq 0)
        } catch {
            return $false
        }
    }
}

function Resolve-BackupEventLogName([string]$preferredLogName) {
    $candidates = New-Object System.Collections.Generic.List[string]

    foreach ($name in @(
        $preferredLogName,
        'Microsoft-Windows-Backup',
        'Microsoft-Windows-Backup/Operational',
        # Fallback per sistemi Win8/10/11 con solo File History (no WSB)
        'Microsoft-Windows-FileHistory-Engine/BackupLog'
    )) {
        $n = [string]$name
        if ([string]::IsNullOrWhiteSpace($n)) { continue }
        # Se in passato era stata salvata come EventLogName una fonte FileHistory, ignorala in modalità WSB/Legacy
        if ($n -like 'Microsoft-Windows-FileHistory*') { continue }
        if (-not $candidates.Contains($n)) { $candidates.Add($n) }
    }

    foreach ($candidate in $candidates) {
        if (Test-EventLogExists $candidate) { return $candidate }
    }

    return $null
}

# [BOOKMARK:BACKUP_MODE]
function Normalize-BackupMode([string]$mode) {
    $m = ([string]$mode).Trim()
    if ([string]::IsNullOrWhiteSpace($m)) { return 'Auto' }

    switch -Regex ($m) {
        '^(Auto)$'        { return 'Auto' }
        '^(WSB|Server)$'  { return 'WSB' }
        '^(FileHistory|FH)$' { return 'FileHistory' }
        '^(Legacy|Win7)$' { return 'Legacy' }
        default { return 'Auto' }
    }
}

function Resolve-WSBEventLogName([string]$preferredLogName) {
    # Come Resolve-BackupEventLogName, ma SENZA fallback su FileHistory.
    $candidates = New-Object System.Collections.Generic.List[string]

    foreach ($name in @(
        $preferredLogName,
        'Microsoft-Windows-Backup',
        'Microsoft-Windows-Backup/Operational',
        'Microsoft-Windows-StorageManagement/Operational',
        'Microsoft-Windows-WindowsBackup/ActionCenter'
    )) {
        $n = [string]$name
        if ([string]::IsNullOrWhiteSpace($n)) { continue }
        # Se in passato era stata salvata come EventLogName una fonte FileHistory, ignorala in modalità WSB/Legacy
        if ($n -like 'Microsoft-Windows-FileHistory*') { continue }
        if (-not $candidates.Contains($n)) { $candidates.Add($n) }
    }

    foreach ($candidate in $candidates) {
        if (Test-EventLogExists $candidate) { return $candidate }
    }

    return $null
}

function Resolve-PrimaryEventLogForMode($cfg) {
    $modeRaw = 'Auto'
    if ($cfg.PSObject.Properties.Match('BackupMode').Count -gt 0 -and $cfg.BackupMode) { $modeRaw = [string]$cfg.BackupMode }
    $mode = Normalize-BackupMode $modeRaw

    switch ($mode) {
        'FileHistory' {
            $fh = 'Microsoft-Windows-FileHistory-Engine/BackupLog'
            if (Test-EventLogExists $fh) { return $fh }
            return $null
        }
        'WSB' { return (Resolve-WSBEventLogName $cfg.EventLogName) }
        'Legacy' { return (Resolve-WSBEventLogName $cfg.EventLogName) }
        default {
            $wsb = Resolve-WSBEventLogName $cfg.EventLogName
            if (-not [string]::IsNullOrWhiteSpace($wsb) -and (Test-EventLogExists $wsb)) { return $wsb }

            $useFH = ($cfg.PSObject.Properties.Match('MonitorFileHistory').Count -gt 0 -and [bool]$cfg.MonitorFileHistory)
            if ($useFH) {
                $fh = 'Microsoft-Windows-FileHistory-Engine/BackupLog'
                if (Test-EventLogExists $fh) { return $fh }
            }

            return $null
        }
    }
}

function Get-FileHistoryOnlyLogs {
    $candidates = New-Object System.Collections.Generic.List[string]
    foreach ($name in @(
        'Microsoft-Windows-FileHistory-Engine/BackupLog',
        'Microsoft-Windows-FileHistory-Core/WHC'
    )) {
        if (-not $candidates.Contains($name)) { $candidates.Add($name) }
    }
    return @($candidates | Where-Object { Test-EventLogExists $_ })
}

function Get-BackupModeHint {
    # Solo per UI/diagnostica: suggerisce la modalità più probabile su questa macchina.
    $hasWBJob = $false
    try { $hasWBJob = [bool](Get-Command 'Get-WBJob' -ErrorAction SilentlyContinue) } catch { $hasWBJob = $false }

    $hasWSBLog = (Test-EventLogExists 'Microsoft-Windows-Backup') -or (Test-EventLogExists 'Microsoft-Windows-Backup/Operational')
    $hasFHLog  = (Test-EventLogExists 'Microsoft-Windows-FileHistory-Engine/BackupLog')

    if ($hasWBJob -or $hasWSBLog) { return 'Server (Windows Server Backup)' }
    if ($hasFHLog) { return 'PC (Cronologia file)' }
    return 'Nessuna fonte rilevata'
}


function Get-AllBackupLogs([string]$preferredLogName) {
    # Restituisce TUTTI i log backup presenti sul sistema corrente.
    # Usata SOLO per lettura snapshot (DAILY/Get-BackupState), NON per event trigger.
    # Perché: il RecordId è locale a ogni log; usarli misti nell'event trigger crea buchi.
    #
    # Windows Server Backup / Backup & Restore (wbadmin):
    #   Microsoft-Windows-Backup
    #   Microsoft-Windows-Backup/Operational
    #   Microsoft-Windows-StorageManagement/Operational
    #   Microsoft-Windows-WindowsBackup/ActionCenter
    # File History (Win8/10/11):
    #   Microsoft-Windows-FileHistory-Engine/BackupLog  (EventID 200=OK, 201/203/204=FAIL)
    #   Microsoft-Windows-FileHistory-Core/WHC
    $candidates = New-Object System.Collections.Generic.List[string]
    foreach ($name in @(
        $preferredLogName,
        'Microsoft-Windows-Backup',
        'Microsoft-Windows-Backup/Operational',
        'Microsoft-Windows-StorageManagement/Operational',
        'Microsoft-Windows-WindowsBackup/ActionCenter',
        'Microsoft-Windows-FileHistory-Engine/BackupLog',
        'Microsoft-Windows-FileHistory-Core/WHC'
    )) {
        $n = [string]$name
        if ([string]::IsNullOrWhiteSpace($n)) { continue }
        # Se in passato era stata salvata come EventLogName una fonte FileHistory, ignorala in modalità WSB/Legacy
        if ($n -like 'Microsoft-Windows-FileHistory*') { continue }
        if (-not $candidates.Contains($n)) { $candidates.Add($n) }
    }
    return @($candidates | Where-Object { Test-EventLogExists $_ })
}

function Get-WSBOnlyLogs([string]$preferredLogName) {
    # Come Get-AllBackupLogs ma SENZA File History.
    # Usata nel DAILY di default per evitare che un successo File History
    # mascheri un problema su Windows Server Backup, o viceversa.
    $candidates = New-Object System.Collections.Generic.List[string]
    foreach ($name in @(
        $preferredLogName,
        'Microsoft-Windows-Backup',
        'Microsoft-Windows-Backup/Operational',
        'Microsoft-Windows-StorageManagement/Operational',
        'Microsoft-Windows-WindowsBackup/ActionCenter'
    )) {
        $n = [string]$name
        if ([string]::IsNullOrWhiteSpace($n)) { continue }
        # Se in passato era stata salvata come EventLogName una fonte FileHistory, ignorala in modalità WSB/Legacy
        if ($n -like 'Microsoft-Windows-FileHistory*') { continue }
        if (-not $candidates.Contains($n)) { $candidates.Add($n) }
    }
    return @($candidates | Where-Object { Test-EventLogExists $_ })
}


# [BOOKMARK:RUNTIME_STATE]
function Get-DefaultRuntimeState {
    return [pscustomobject]@{
        LastProcessedEventRecordId = 0
        LastProcessedEventLogName  = ''
        IsPrimed                   = $false
        LastRun                    = [pscustomobject]@{}
        PerLogState                = [pscustomobject]@{}
    }
}

function Save-RuntimeState($state) {
    try {
        Ensure-Dir $ConfigDir
        $state | ConvertTo-Json -Depth 8 | Set-Content -Path $RuntimeStatePath -Encoding UTF8 -Force
    } catch { }
}

function Load-RuntimeState {
    try {
        Ensure-Dir $ConfigDir
        if (-not (Test-Path $RuntimeStatePath)) { return (Get-DefaultRuntimeState) }

        $raw = Get-Content $RuntimeStatePath -Raw -Encoding UTF8
        if ([string]::IsNullOrWhiteSpace($raw)) { return (Get-DefaultRuntimeState) }

        $state = $raw | ConvertFrom-Json
        if ($null -eq $state) { return (Get-DefaultRuntimeState) }

        if ($state.PSObject.Properties.Match('LastProcessedEventRecordId').Count -eq 0) {
            Set-OrAddProp $state 'LastProcessedEventRecordId' 0
        }
        if ($state.PSObject.Properties.Match('LastProcessedEventLogName').Count -eq 0) {
            Set-OrAddProp $state 'LastProcessedEventLogName' ''
        }
        if ($state.PSObject.Properties.Match('IsPrimed').Count -eq 0) {
            Set-OrAddProp $state 'IsPrimed' $false
        }
        if ($state.PSObject.Properties.Match('LastRun').Count -eq 0 -or $null -eq $state.LastRun) {
            Set-OrAddProp $state 'LastRun' ([pscustomobject]@{})
        }
        if ($state.PSObject.Properties.Match('PerLogState').Count -eq 0 -or $null -eq $state.PerLogState) {
            Set-OrAddProp $state 'PerLogState' ([pscustomobject]@{})
        }

        return $state
    } catch {
        return (Get-DefaultRuntimeState)
    }
}

# [BOOKMARK:DIAG_LOG]
# Log silenzioso per debug dei task (utile quando la finestra PowerShell è nascosta).
function Write-DiagLog([string]$msg, [string]$level = 'INFO') {
    if ([string]::IsNullOrWhiteSpace($msg)) { return }
    try {
        $p = $script:DiagLogPath
        if ([string]::IsNullOrWhiteSpace($p)) { return }
        Ensure-Dir (Split-Path $p -Parent)
        $line = "[{0}] [{1}] {2}" -f (Get-Date).ToString("yyyy-MM-dd HH:mm:ss"), $level.PadRight(5), $msg
        Add-Content -Path $p -Value $line -Encoding UTF8 -Force
        # Mantieni il log sotto 500KB (taglia le prime 200 righe quando supera)
        try {
            $fi = [System.IO.FileInfo]$p
            if ($fi.Length -gt 512000) {
                $lines = [System.IO.File]::ReadAllLines($p, [System.Text.Encoding]::UTF8)
                $trimmed = $lines | Select-Object -Skip 200
                [System.IO.File]::WriteAllLines($p, $trimmed, [System.Text.Encoding]::UTF8)
            }
        } catch { }
    } catch { }
}

function Write-DiagSep([string]$label = '') {
    $sep = if ($label) { "--- $label ---" } else { '---' }
    Write-DiagLog $sep 'INFO'
}

# [BOOKMARK:LASTRUN_STAMP]
# Scrive un timestamp nel runtime_state per capire se i task stanno davvero eseguendo -RunEvent/-RunDailyCheck.
function Touch-LastRun([string]$kind) {
    if ([string]::IsNullOrWhiteSpace($kind)) { return }
    try {
        $rt = Load-RuntimeState

        if ($rt.PSObject.Properties.Match('LastRun').Count -eq 0 -or $null -eq $rt.LastRun) {
            Set-OrAddProp $rt 'LastRun' ([pscustomobject]@{})
        }

        $stamp = (Get-Date).ToString('o')

        if ($rt.LastRun -is [hashtable]) {
            $rt.LastRun[$kind] = $stamp
        } else {
            try { $rt.LastRun | Add-Member -NotePropertyName $kind -NotePropertyValue $stamp -Force } catch { }
        }

        Save-RuntimeState $rt
    } catch { }
}


function Get-EventRecordId($event) {
    if ($null -eq $event) { return [int64]0 }

    foreach ($propName in @('RecordId','EventRecordID','EventRecordId')) {
        try {
            $prop = $event.PSObject.Properties[$propName]
            if ($null -ne $prop) { return [int64]$prop.Value }
        } catch { }
    }

    try { return [int64]$event.RecordId } catch { return [int64]0 }
}

function New-EventDerivedState($event, [string]$classification) {
    $t = $event.TimeCreated
    $id = Safe-Int $event.Id 0
    $rid = Get-EventRecordId $event
    $short = Get-BackupEventShortMessage $event

    $status = if ($classification -eq 'OK') { 'OK' } elseif ($classification -eq 'FAIL') { 'FAIL' } else { 'UNKNOWN' }

    $msg = switch ($status) {
        'OK'   { "Backup completato: $($t.ToString('dd/MM/yyyy HH:mm:ss')) (EventID: $id, RecordId: $rid)" }
        'FAIL' { "Backup FALLITO: $($t.ToString('dd/MM/yyyy HH:mm:ss')) (EventID: $id, RecordId: $rid)" }
        default { "Evento non classificato: $($t.ToString('dd/MM/yyyy HH:mm:ss')) (EventID: $id, RecordId: $rid)" }
    }

    if ($short) { $msg += " - $short" }

    return [pscustomobject]@{
        TriggerEvent       = $event
        EventRecordId      = $rid
        LastRelevantEvent  = $event
        LastSuccessEvent   = $(if ($status -eq 'OK') { $event } else { $null })
        LastFailureEvent   = $(if ($status -eq 'FAIL') { $event } else { $null })
        Status             = $status
        Message            = $msg
    }
}

# [BOOKMARK:EVENT_TRIGGER_MULTI_LOG]
function Get-TriggerEventLogNames($cfg) {
    # Log da usare per il trigger EVENT (notifiche immediate).
    # Dipende da BackupMode:
    #  - WSB     : solo log backup "server" (no FileHistory)
    #  - FileHistory : solo FileHistory-Engine/BackupLog
    #  - Legacy  : solo log backup "classico" (no FileHistory)
    #  - Auto    : log principale + (opzionale) FileHistory se MonitorFileHistory=true
    $logs = New-Object System.Collections.Generic.List[string]
    $mode = Normalize-BackupMode ([string]$cfg.BackupMode)

    switch ($mode) {
        'FileHistory' {
            # FIX: include sia FileHistory-Engine/BackupLog che FileHistory-Core/WHC
            # perche su Win10/11 gli eventi reali arrivano su WHC (EventID 201)
            $fhEngineLog = 'Microsoft-Windows-FileHistory-Engine/BackupLog'
            $fhCoreLog   = 'Microsoft-Windows-FileHistory-Core/WHC'
            if (Test-EventLogExists $fhEngineLog) { $logs.Add($fhEngineLog) | Out-Null }
            if (Test-EventLogExists $fhCoreLog)   { $logs.Add($fhCoreLog)   | Out-Null }
        }
        'WSB' {
            $resolved = Resolve-WSBEventLogName $cfg.EventLogName
            if (-not [string]::IsNullOrWhiteSpace($resolved) -and (Test-EventLogExists $resolved)) {
                $logs.Add($resolved) | Out-Null
            }
        }
        'Legacy' {
            $resolved = Resolve-WSBEventLogName $cfg.EventLogName
            if (-not [string]::IsNullOrWhiteSpace($resolved) -and (Test-EventLogExists $resolved)) {
                $logs.Add($resolved) | Out-Null
            }
        }
        default {
            $resolved = Resolve-WSBEventLogName $cfg.EventLogName
            if (-not [string]::IsNullOrWhiteSpace($resolved) -and (Test-EventLogExists $resolved)) {
                $logs.Add($resolved) | Out-Null
            }

            $useFH = ($cfg.PSObject.Properties.Match('MonitorFileHistory').Count -gt 0 -and [bool]$cfg.MonitorFileHistory)
            if ($useFH) {
                $fhLog = 'Microsoft-Windows-FileHistory-Engine/BackupLog'
                if (Test-EventLogExists $fhLog) {
                    if (-not $logs.Contains($fhLog)) { $logs.Add($fhLog) | Out-Null }
                }
            }
        }
    }

    return @($logs.ToArray())
}


function Get-OrCreate-PerLogEntry($rt, [string]$logName) {
    if ($null -eq $rt) { return $null }

    if ($rt.PSObject.Properties.Match('PerLogState').Count -eq 0 -or $null -eq $rt.PerLogState) {
        Set-OrAddProp $rt 'PerLogState' @{}
    }

    # JSON -> PSCustomObject: converti in hashtable per poter usare chiavi con '/'
    if ($rt.PerLogState -isnot [hashtable]) {
        $h = @{}
        try {
            foreach ($p in $rt.PerLogState.PSObject.Properties) { $h[$p.Name] = $p.Value }
        } catch { }
        $rt.PerLogState = $h
    }

    if (-not $rt.PerLogState.ContainsKey($logName) -or $null -eq $rt.PerLogState[$logName]) {
        $rt.PerLogState[$logName] = @{ LastRecordId = [int64]0; IsPrimed = $false }
    }

    $entry = $rt.PerLogState[$logName]

    # Entry può essere PSCustomObject se arriva da JSON: normalizza
    if ($entry -isnot [hashtable]) {
        $eh = @{}
        try {
            foreach ($p in $entry.PSObject.Properties) { $eh[$p.Name] = $p.Value }
        } catch { }
        $entry = $eh
        $rt.PerLogState[$logName] = $entry
    }

    if (-not $entry.ContainsKey('LastRecordId')) { $entry['LastRecordId'] = [int64]0 }
    if (-not $entry.ContainsKey('IsPrimed'))    { $entry['IsPrimed']    = $false }

    return $entry
}

function Prime-TriggerRuntimeState($cfg) {
    $logs = @(Get-TriggerEventLogNames $cfg)
    if (-not $logs -or $logs.Count -eq 0) { return }

    $rt = Load-RuntimeState

    foreach ($ln in $logs) {
        try {
            if (-not (Test-EventLogExists $ln)) { continue }

            $entry = Get-OrCreate-PerLogEntry $rt $ln
            $alreadyPrimed = ([bool]$entry['IsPrimed'])
            $lastRid = [int64]$entry['LastRecordId']

            # IMPORTANTISSIMO: non "resettiamo" il cursore ad ogni reinstall dei task.
            # Primiamo SOLO se non era già primed (o LastRecordId=0).
            if ($alreadyPrimed -and $lastRid -gt 0) { continue }

            $latest = Get-WinEvent -LogName $ln -MaxEvents 1 -ErrorAction Stop | Select-Object -First 1
            $rid = if ($latest) { Get-EventRecordId $latest } else { [int64]0 }

            $entry['LastRecordId'] = [int64]$rid
            $entry['IsPrimed']     = $true
        } catch { }
    }

    # Mantieni i campi legacy coerenti (compatibilità retro)
    $primary = $logs[0]
    $primaryEntry = Get-OrCreate-PerLogEntry $rt $primary
    $rt.LastProcessedEventRecordId = [int64]$primaryEntry['LastRecordId']
    $rt.LastProcessedEventLogName  = [string]$primary
    $rt.IsPrimed = $true

    Save-RuntimeState $rt
}


function Get-NewTriggerEventStates($cfg) {
    $logs = @(Get-TriggerEventLogNames $cfg)
    if (-not $logs -or $logs.Count -eq 0) { return @() }

    $successIds      = @($cfg.SuccessEventIds | ForEach-Object { Safe-Int $_ 0 }) | Where-Object { $_ -gt 0 }
    $failureIds      = @($cfg.FailureEventIds | ForEach-Object { Safe-Int $_ 0 }) | Where-Object { $_ -gt 0 }
    $successPatterns = @($cfg.SuccessMessagePatterns | ForEach-Object { [string]$_ } | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })
    $failurePatterns = @($cfg.FailureMessagePatterns | ForEach-Object { [string]$_ } | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })
    $ignorePatterns  = @($cfg.IgnoreMessagePatterns  | ForEach-Object { [string]$_ } | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })

    $rt = Load-RuntimeState

    # Migrazione: vecchio stato single-log -> PerLogState
    if (-not [string]::IsNullOrWhiteSpace($rt.LastProcessedEventLogName)) {
        $legacyLog = [string]$rt.LastProcessedEventLogName
        $legacyRid = [int64]$rt.LastProcessedEventRecordId
        $legacyEntry = Get-OrCreate-PerLogEntry $rt $legacyLog

        if ([int64]$legacyEntry['LastRecordId'] -lt $legacyRid) { $legacyEntry['LastRecordId'] = $legacyRid }
        if (-not [bool]$legacyEntry['IsPrimed']) { $legacyEntry['IsPrimed'] = [bool]$rt.IsPrimed }
    }

    $scanCount = [Math]::Max((Safe-Int $cfg.MaxEventsScan 120), 40)

    $out = New-Object System.Collections.Generic.List[object]

    foreach ($ln in $logs) {
        # Se il log non esiste, salta
        if (-not (Test-EventLogExists $ln)) { continue }

        $entry = Get-OrCreate-PerLogEntry $rt $ln
        $lastRid = [int64]$entry['LastRecordId']

        # Priming per quel log: evita spam alla prima installazione/attivazione
        if (-not [bool]$entry['IsPrimed']) {
            try {
                $latest = Get-WinEvent -LogName $ln -MaxEvents 1 -ErrorAction Stop | Select-Object -First 1
                $rid = if ($latest) { Get-EventRecordId $latest } else { [int64]0 }
                $entry['LastRecordId'] = [int64]$rid
                $entry['IsPrimed']     = $true
            } catch { }
            continue
        }

        # Legge tutti gli eventi con RecordId > ultimo processato (per quel log)
        $events = @()
        try {
            if ($lastRid -gt 0) {
                $xpathQuery = "*[System[EventRecordID > $lastRid]]"
                $events = @(Get-WinEvent -LogName $ln -FilterXPath $xpathQuery -MaxEvents $scanCount -ErrorAction Stop)
            } else {
                $events = @(Get-WinEvent -LogName $ln -MaxEvents $scanCount -ErrorAction Stop)
            }
        } catch [System.Exception] {
            if ($_.Exception.Message -match "No events were found") { $events = @() }
            else { $events = @() }
        }

        if (-not $events -or $events.Count -eq 0) { continue }

        $rows = foreach ($ev in $events) {
            $cls = Get-BackupEventClassification -event $ev -successIds $successIds -failureIds $failureIds -successPatterns $successPatterns -failurePatterns $failurePatterns -ignorePatterns $ignorePatterns
            [pscustomobject]@{
                Event          = $ev
                RecordId       = Get-EventRecordId $ev
                Classification = $cls
            }
        }

        # Avanza sempre il cursore (anche su IGNORE/UNKNOWN) per evitare ripetizioni
        $newRowsAll = @($rows | Where-Object { [int64]$_.RecordId -gt $lastRid } | Sort-Object -Property RecordId)
        if ($newRowsAll.Count -eq 0) { continue }

        $maxRidAll = ($newRowsAll | Measure-Object -Property RecordId -Maximum).Maximum
        $entry['LastRecordId'] = [int64]$maxRidAll
        $entry['IsPrimed']     = $true

        foreach ($row in $newRowsAll) {
            if ($row.Classification -in @('OK','FAIL')) {
                $out.Add((New-EventDerivedState -event $row.Event -classification $row.Classification))
            }
        }
    }

    # Mantieni i campi legacy coerenti (compatibilità retro)
    $primary = $logs[0]
    $primaryEntry = Get-OrCreate-PerLogEntry $rt $primary
    $rt.LastProcessedEventRecordId = [int64]$primaryEntry['LastRecordId']
    $rt.LastProcessedEventLogName  = [string]$primary
    $rt.IsPrimed = $true

    Save-RuntimeState $rt

    # Ordina per tempo (non solo RecordId, che è locale al log)
    $arr = @($out.ToArray() | Sort-Object { $_.TriggerEvent.TimeCreated })
    return $arr
}

# [BOOKMARK:BACKUP_STATE]
function Get-BackupEventShortMessage($event) {
    try {
        $msg = ''
        try { $msg = [string]$event.Message } catch { $msg = '' }
        if ([string]::IsNullOrWhiteSpace($msg)) { return '' }

        $lines = @(
            $msg -split "(`r`n|`n|`r)" |
            ForEach-Object { ([string]$_).Trim() } |
            Where-Object { -not [string]::IsNullOrWhiteSpace($_) }
        )

        if (-not $lines -or $lines.Count -eq 0) {
            $line = $msg.Trim()
        } else {
            $line = $null
            foreach ($candidate in $lines) {
                $c = $candidate.ToLowerInvariant()
                if ($c -match '(non riuscit|failed|failure|errore|error|spazio|space|i/o|completat|completed|success)') {
                    $line = $candidate
                    break
                }
            }

            if ([string]::IsNullOrWhiteSpace($line)) {
                $line = ($lines | Where-Object { $_ -notmatch '^(backup|descrizione|description|stato|status)\s*:?$' } | Select-Object -First 1)
            }
            if ([string]::IsNullOrWhiteSpace($line)) { $line = $lines[0] }
        }

        $line = (($line -replace '\s+', ' ').Trim())
        if ($line.Length -gt 180) { $line = $line.Substring(0,180) + '...' }
        return $line
    } catch {
        return ''
    }
}

function Test-MessageContainsAny([string]$text, [string[]]$patterns) {
    if ([string]::IsNullOrWhiteSpace($text)) { return $false }
    foreach ($pattern in @($patterns)) {
        $p = [string]$pattern
        if ([string]::IsNullOrWhiteSpace($p)) { continue }
        if ($text.Contains($p.ToLowerInvariant())) { return $true }
    }
    return $false
}

function Get-BackupEventClassification(
    $event,
    [int[]]$successIds,
    [int[]]$failureIds,
    [string[]]$successPatterns,
    [string[]]$failurePatterns,
    [string[]]$ignorePatterns
) {
    if ($null -eq $event) { return 'UNKNOWN' }

    $id = Safe-Int $event.Id 0

    $msg = ''
    try { $msg = [string]$event.Message } catch { $msg = '' }
    $msgLower = if ([string]::IsNullOrWhiteSpace($msg)) { '' } else { $msg.ToLowerInvariant() }

    $providerLower = ''
    try { $providerLower = ([string]$event.ProviderName).ToLowerInvariant() } catch { $providerLower = '' }

    $levelLower = ''
    try { $levelLower = ([string]$event.LevelDisplayName).ToLowerInvariant() } catch { $levelLower = '' }
    $levelInt = 0
    try { $levelInt = [int]$event.Level } catch { $levelInt = 0 }

    $isErrorLevel = ($levelInt -eq 2) -or $levelLower.Contains('error') -or $levelLower.Contains('errore')
    $isWarningLevel = ($levelInt -eq 3) -or $levelLower.Contains('warning') -or $levelLower.Contains('avviso')
    $isInfoLevel = ($levelInt -eq 4) -or $levelLower.Contains('information') -or $levelLower.Contains('informazione')

    if (Test-MessageContainsAny -text $msgLower -patterns $ignorePatterns) { return 'IGNORE' }

    $hasFailureText = Test-MessageContainsAny -text $msgLower -patterns $failurePatterns
    $hasSuccessText = Test-MessageContainsAny -text $msgLower -patterns $successPatterns

    if ($hasFailureText) { return 'FAIL' }
    if ($hasSuccessText -and -not $isErrorLevel) { return 'OK' }

    # Gli ID restano solo come supporto secondario, non come base principale.
    if (($id -in $failureIds) -and ($isErrorLevel -or $isWarningLevel -or $providerLower.Contains('backup'))) {
        return 'FAIL'
    }
    if (($id -in $successIds) -and -not $isErrorLevel) {
        return 'OK'
    }

    $hasGenericFailWord = $msgLower -match '(non riuscit|failed|failure|errore|error|insufficient|space|spazio|i/o|disk full|disco pieno)'
    $hasGenericOkWord   = $msgLower -match '(completat|completed|success)'

    if (($isErrorLevel -or $isWarningLevel) -and $hasGenericFailWord) { return 'FAIL' }
    if ((-not $isErrorLevel) -and $hasGenericOkWord -and -not $hasGenericFailWord) { return 'OK' }

    if ($providerLower.Contains('backup') -and $isErrorLevel -and -not $hasSuccessText) {
        return 'FAIL'
    }

    if ($providerLower.Contains('backup') -and $isInfoLevel -and $hasGenericOkWord -and -not $hasFailureText) {
        return 'OK'
    }

    return 'UNKNOWN'
}

function Get-WBJobState($cfg) {
    # Interroga direttamente il motore Windows Server Backup via Get-WBJob.
    # Piu affidabile degli event log: funziona anche quando Windows non riesce
    # a scrivere eventi (es. stacco HD brutale, crash del servizio di log).
    # Disponibile solo dove e installata la feature WindowsServerBackup.
    # Su Windows 10/11 o sistemi senza la feature restituisce $null silenziosamente.
    #
    # IMPORTANTE: popola LastSuccessEvent/LastFailureEvent con oggetti sintetici
    # che hanno almeno TimeCreated, cosi Evaluate-MissingBackup non converte
    # un backup OK in MISSING per via di LastSuccessEvent = $null.

    try {
        if (-not (Get-Command 'Get-WBJob' -ErrorAction SilentlyContinue)) { return $null }

        $job = Get-WBJob -Previous 1 -ErrorAction Stop
        if ($null -eq $job) { return $null }

        $jobState  = [string]$job.JobState
        $errDesc   = [string]$job.ErrorDescription
        $startTime = $job.StartTime
        $endTime   = $job.EndTime

        $successStates = @('Completed','CompletedWithWarnings')
        $failureStates = @('Failed','Aborted','Stopped')

        $status       = 'UNKNOWN'
        $message      = ''
        $lastRelevant = $null
        $lastSuccess  = $null
        $lastFailure  = $null

        if ($jobState -in $successStates) {
            $status  = 'OK'
            $refTime = if ($endTime) { $endTime } elseif ($startTime) { $startTime } else { Get-Date }
            $message = "Backup completato (WBJob): $($refTime.ToString('dd/MM/yyyy HH:mm')) - Stato: $jobState"
            # Oggetto sintetico con TimeCreated: necessario per Evaluate-MissingBackup
            $lastRelevant = [pscustomobject]@{ TimeCreated = $refTime }
            $lastSuccess  = [pscustomobject]@{ TimeCreated = $refTime }

        } elseif ($jobState -in $failureStates) {
            $status  = 'FAIL'
            $refTime = if ($endTime) { $endTime } elseif ($startTime) { $startTime } else { Get-Date }
            $message = "Backup FALLITO (WBJob): $($refTime.ToString('dd/MM/yyyy HH:mm')) - Stato: $jobState"
            if (-not [string]::IsNullOrWhiteSpace($errDesc)) { $message += " - $errDesc" }
            $lastRelevant = [pscustomobject]@{ TimeCreated = $refTime }
            $lastFailure  = [pscustomobject]@{ TimeCreated = $refTime }

        } elseif ($jobState -eq 'Running') {
            # Backup in corso: non classificabile, lascia decidere al fallback event log
            $status    = 'RUNNING'
            $startDesc = if ($startTime) { $startTime.ToString('dd/MM/yyyy HH:mm') } else { 'ora sconosciuta' }
            $message   = "Backup in corso (WBJob): avviato $startDesc"

        } else {
            $status  = 'UNKNOWN'
            $message = "Stato WBJob non riconosciuto: $jobState"
        }

        return [pscustomobject]@{
            Source            = 'WBJob'
            Status            = $status
            Message           = $message
            JobState          = $jobState
            StartTime         = $startTime
            EndTime           = $endTime
            LastSuccessEvent  = $lastSuccess
            LastFailureEvent  = $lastFailure
            LastRelevantEvent = $lastRelevant
        }
    } catch {
        # Get-WBJob non disponibile o errore: restituisce $null, si usa fallback event log
        return $null
    }
}

function Get-FileHistoryLastBackupTime($cfg = $null) {
    try {
        $dataPaths = @()

        # Fonte 1: path salvato nella config (funziona anche come SYSTEM)
        if ($null -ne $cfg) {
            $saved = ''
            try { $saved = [string]$cfg.FileHistoryDataPath } catch { }
            if (-not [string]::IsNullOrWhiteSpace($saved) -and (Test-Path $saved)) {
                $dataPaths += $saved
            }
        }

        # Fonte 2: ricerca dinamica dal Config XML (funziona solo come utente)
        if ($dataPaths.Count -eq 0) {
            $configPaths = @()
            $configPaths += Join-Path $env:USERPROFILE 'AppData\Local\Microsoft\Windows\FileHistory\Configuration\Config1.xml'

            try {
                $usersRoot = Split-Path (Split-Path $env:USERPROFILE -Parent) -Parent
                Get-ChildItem $usersRoot -Directory -ErrorAction Stop | ForEach-Object {
                    $p = Join-Path $_.FullName 'AppData\Local\Microsoft\Windows\FileHistory\Configuration\Config1.xml'
                    if ($p -notin $configPaths) { $configPaths += $p }
                }
            } catch { }

            foreach ($configXmlPath in $configPaths) {
                try {
                    if (-not (Test-Path $configXmlPath)) { continue }
                    [xml]$fhCfg = Get-Content $configXmlPath -ErrorAction Stop
                    $targetUrl = $fhCfg.DataProtectionUserConfig.Target.TargetUrl
                    $storePath = $fhCfg.DataProtectionUserConfig.Target.TargetBackupStorePath
                    if ([string]::IsNullOrWhiteSpace($targetUrl) -or [string]::IsNullOrWhiteSpace($storePath)) { continue }
                    $dp = Join-Path $targetUrl (Join-Path 'FileHistory' $storePath)
                    if ((Test-Path $dp) -and ($dp -notin $dataPaths)) { $dataPaths += $dp }
                } catch { }
            }
        }

        $bestTime = $null

        foreach ($dataPath in $dataPaths) {
            try {
                $cutoff = (Get-Date).AddDays(-7)
                $latest = Get-ChildItem -Path $dataPath -Recurse -File -ErrorAction Stop |
                          Where-Object { $_.LastWriteTime -gt $cutoff } |
                          Sort-Object LastWriteTime -Descending |
                          Select-Object -First 1

                if ($null -eq $latest) {
                    $latest = Get-ChildItem -Path $dataPath -Recurse -File -ErrorAction Stop |
                              Sort-Object LastWriteTime -Descending |
                              Select-Object -First 1
                }

                if ($null -eq $latest) { continue }

                if ($null -eq $bestTime -or $latest.LastWriteTime -gt $bestTime) {
                    $bestTime = $latest.LastWriteTime
                }
            } catch { }
        }

        return $bestTime
    } catch {
        return $null
    }
}
function Get-BackupState($cfg) {
    # v5: logica a cascata per massima copertura universale, ma con BackupMode selezionabile.
    # BackupMode:
    #   - WSB        : usa Get-WBJob (se disponibile) + log WSB (no FileHistory)
    #   - FileHistory: usa SOLO log File History (no Get-WBJob)
    #   - Legacy     : usa solo log WSB/Backup classico (no FileHistory, no Get-WBJob)
    #   - Auto       : comportamento storico (Get-WBJob se disponibile + fallback; FileHistory solo se abilitato)
    $mode = Normalize-BackupMode ([string]$cfg.BackupMode)

    # ── Fonte 1: Get-WBJob (solo Auto/WSB) ────────────────────────────────
    $useWBJob = ($mode -in @('Auto','WSB'))
    if ($useWBJob) {
        $wbState = Get-WBJobState $cfg
        if ($null -ne $wbState -and $wbState.Status -ne 'UNKNOWN' -and $wbState.Status -ne 'RUNNING') {
            return $wbState
        }
    }

    # ── Fonte 2: Event Log (fallback) ─────────────────────────────────────
    $allLogs = @()
    switch ($mode) {
        'FileHistory' {
            # Fonte 0: cartella destinazione File History (più affidabile dei log)
            $fhLastTime = Get-FileHistoryLastBackupTime $cfg
            if ($null -ne $fhLastTime) {
                $span = (Get-Date) - $fhLastTime
                $ageStr = if ($span.TotalHours -lt 1) {
                    "$([int]$span.TotalMinutes) minuti fa"
                } elseif ($span.TotalHours -lt 24) {
                    "$([int]$span.Hours) ore $([int]$span.Minutes) min fa"
                } else {
                    "$([int]$span.TotalDays) giorni fa"
                }
                $state = [pscustomobject]@{
                    LastRelevantEvent = $null
                    LastSuccessEvent  = $null
                    LastFailureEvent  = $null
                    Status  = 'OK'
                    Message = "Backup File History: $($fhLastTime.ToString('dd/MM/yyyy HH:mm')) - $ageStr"
                }
                Write-DiagLog "FileHistory fonte cartella: $fhLastTime ($ageStr)"
                return $state
            }
            # Fallback: log eventi
            $allLogs = @(Get-FileHistoryOnlyLogs)
        }
        'WSB' {
            $allLogs = @(Get-WSBOnlyLogs $cfg.EventLogName)
        }
        'Legacy' {
            $allLogs = @(Get-WSBOnlyLogs $cfg.EventLogName)
        }
        default {
            $useAllLogs = ($cfg.PSObject.Properties.Match('MonitorFileHistory').Count -gt 0 -and [bool]$cfg.MonitorFileHistory)
            $allLogs = @(if ($useAllLogs) { Get-AllBackupLogs $cfg.EventLogName } else { Get-WSBOnlyLogs $cfg.EventLogName })
        }
    }

    if (-not $allLogs -or $allLogs.Count -eq 0) {
        $msg = switch ($mode) {
            'FileHistory' { "Nessun registro eventi File History trovato. Cercati: Microsoft-Windows-FileHistory-Engine/BackupLog, FileHistory-Core/WHC" }
            'WSB'         { "Nessun registro eventi Windows Backup/WSB trovato. Cercati: Microsoft-Windows-Backup, /Operational, StorageManagement/Operational, WindowsBackup/ActionCenter" }
            'Legacy'      { "Nessun registro eventi Backup classico trovato. Cercati: Microsoft-Windows-Backup, /Operational, StorageManagement/Operational, WindowsBackup/ActionCenter" }
            default       { "Nessun registro eventi backup trovato. Cercati: Microsoft-Windows-Backup, /Operational, FileHistory-Engine/BackupLog, StorageManagement/Operational" }
        }

        return [pscustomobject]@{
            LastRelevantEvent = $null
            LastSuccessEvent  = $null
            LastFailureEvent  = $null
            Status = 'UNKNOWN'
            Message = $msg
        }
    }

    $successIds      = @($cfg.SuccessEventIds | ForEach-Object { Safe-Int $_ 0 }) | Where-Object { $_ -gt 0 }
    $failureIds      = @($cfg.FailureEventIds | ForEach-Object { Safe-Int $_ 0 }) | Where-Object { $_ -gt 0 }
    $successPatterns = @($cfg.SuccessMessagePatterns | ForEach-Object { [string]$_ } | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })
    $failurePatterns = @($cfg.FailureMessagePatterns | ForEach-Object { [string]$_ } | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })
    $ignorePatterns  = @($cfg.IgnoreMessagePatterns  | ForEach-Object { [string]$_ } | Where-Object { -not [string]::IsNullOrWhiteSpace($_) })

    $state = [pscustomobject]@{
        LastRelevantEvent = $null
        LastSuccessEvent  = $null
        LastFailureEvent  = $null
        Status = 'UNKNOWN'
        Message = ''
    }

    try {
        $events = @(
            $allLogs | ForEach-Object {
                $logName = $_
                try { Get-WinEvent -LogName $logName -MaxEvents ([int]$cfg.MaxEventsScan) -ErrorAction Stop } catch { @() }
            }
        ) | Sort-Object TimeCreated -Descending | Select-Object -First ([int]$cfg.MaxEventsScan)

        $classified = foreach ($ev in $events) {
            $cls = Get-BackupEventClassification -event $ev -successIds $successIds -failureIds $failureIds -successPatterns $successPatterns -failurePatterns $failurePatterns -ignorePatterns $ignorePatterns
            [pscustomobject]@{
                Event = $ev
                Classification = $cls
            }
        }

        $state.LastRelevantEvent = ($classified | Where-Object { $_.Classification -in @('OK','FAIL') } | Select-Object -First 1).Event
        $state.LastSuccessEvent  = ($classified | Where-Object { $_.Classification -eq 'OK' } | Select-Object -First 1).Event
        $state.LastFailureEvent  = ($classified | Where-Object { $_.Classification -eq 'FAIL' } | Select-Object -First 1).Event

        if (-not $state.LastRelevantEvent) {
            $state.Status = 'UNKNOWN'
            $state.Message = 'Nessun evento classificabile trovato nel registro backup.'
            return $state
        }

        $t  = $state.LastRelevantEvent.TimeCreated
        $id = Safe-Int $state.LastRelevantEvent.Id 0
        $short = Get-BackupEventShortMessage $state.LastRelevantEvent
        $cls = Get-BackupEventClassification -event $state.LastRelevantEvent -successIds $successIds -failureIds $failureIds -successPatterns $successPatterns -failurePatterns $failurePatterns -ignorePatterns $ignorePatterns

        if ($cls -eq 'OK') {
            $state.Status = 'OK'
            $state.Message = "Backup completato: $($t.ToString('dd/MM/yyyy HH:mm')) (EventID: $id)"
            if ($short) { $state.Message += " - $short" }
        } elseif ($cls -eq 'FAIL') {
            $state.Status = 'FAIL'
            $state.Message = "Backup FALLITO: $($t.ToString('dd/MM/yyyy HH:mm')) (EventID: $id)"
            if ($short) { $state.Message += " - $short" }
        } else {
            $state.Status = 'UNKNOWN'
            $state.Message = "Ultimo evento non classificato: $($t.ToString('dd/MM/yyyy HH:mm')) (EventID: $id)"
            if ($short) { $state.Message += " - $short" }
        }
    } catch {
        $state.Status = 'UNKNOWN'
        $state.Message = "Errore lettura log: $($_.Exception.Message)"
    }

    return $state
}

function Evaluate-MissingBackup($cfg, $state) {
    # FIX: non converte UNKNOWN in MISSING.
    # UNKNOWN significa "non riesco a determinare lo stato" (log non leggibile,
    # errore tecnico, nessun evento classificabile) -- diverso da backup mancante.
    # Notifichiamo UNKNOWN separatamente cosi l'utente sa che il monitor ha un problema.
    if ($state.Status -eq 'FAIL')    { return $state }
    if ($state.Status -eq 'UNKNOWN') { return $state }

    $hours = [double]$cfg.MissingIfSuccessOlderThanHours

    if (-not $state.LastSuccessEvent) {
        # Se lo stato è già OK (es. FileHistory da cartella), non sovrascrivere
        if ($state.Status -eq 'OK') { return $state }

        # FIX v5.1: se non è mai stato trovato un evento di successo backup,
        # NON segnalare MISSING (falso allarme su PC nuovi o senza backup configurato).
        # Lo stato UNKNOWN viene notificato solo se NotifyIfNeverBackedUp = true.
        $notifyNever = $cfg.PSObject.Properties.Match('NotifyIfNeverBackedUp').Count -gt 0 -and [bool]$cfg.NotifyIfNeverBackedUp
        if (-not $notifyNever) {
            $state.Status = 'UNKNOWN'
            $state.Message = 'Nessun backup rilevato: nessun evento di successo trovato nei log. In attesa del primo backup.'
            return $state
        }
        $state.Status = 'MISSING'
        $state.Message = 'Backup mancante: nessun evento di successo trovato nel periodo di scansione.'
        return $state
    }

    $age = (New-TimeSpan -Start $state.LastSuccessEvent.TimeCreated -End (Get-Date)).TotalHours
    if ($age -gt $hours) {
        $state.Status = 'MISSING'
        $state.Message = "Backup mancante: ultimo successo $([math]::Round($age,1)) ore fa (soglia: $hours h)."
        return $state
    }

    $state.Status = 'OK'
    $state.Message = "Ultimo backup OK $([math]::Round($age,1)) ore fa (soglia: $hours h)."
    return $state
}

function Should-Notify-Event($cfg, $state) {
    if ($state.Status -eq 'OK') { return [bool]$cfg.SendOnSuccessEvent }
    if ($state.Status -ne 'FAIL') { return $false }

    # Cooldown: se EventCooldownMinutes > 0, controlla quando e' stata mandata l'ultima notifica FAIL
    $cooldownMin = 0
    if ($cfg.PSObject.Properties.Match('EventCooldownMinutes').Count -gt 0) {
        $cooldownMin = [int]$cfg.EventCooldownMinutes
    }
    if ($cooldownMin -gt 0) {
        try {
            $rt = Load-RuntimeState
            if ($rt.PSObject.Properties.Match('LastFailNotifyTime').Count -gt 0 -and
                -not [string]::IsNullOrWhiteSpace($rt.LastFailNotifyTime)) {
                $last = [datetime]::Parse($rt.LastFailNotifyTime)
                $minAgo = ([datetime]::Now - $last).TotalMinutes
                if ($minAgo -lt $cooldownMin) {
                    Write-DiagLog ("Cooldown attivo: ultima notifica FAIL {0:F1} min fa (cooldown {1} min) -- skip" -f $minAgo, $cooldownMin) 'INFO'
                    return $false
                }
            }
        } catch { }
    }
    return $true
}

function Save-LastFailNotifyTime {
    try {
        $rt = Load-RuntimeState
        Set-OrAddProp $rt 'LastFailNotifyTime' ([datetime]::Now.ToString('o'))
        Save-RuntimeState $rt
    } catch { }
}

function Should-Notify-Daily($cfg, $state) {
    if (-not [bool]$cfg.DailyCheckEnabled) { return $false }
    if ($cfg.DailyNotifyMode -eq 'Always') { return $true }
    # FIX v5.1: UNKNOWN non notificato di default - copre il caso "PC nuovo, backup mai eseguito".
    # Solo FAIL e MISSING generano notifiche.
    return ($state.Status -eq 'FAIL' -or $state.Status -eq 'MISSING')
}

# [BOOKMARK:SMTP_TEST]
function Test-SmtpConnectivity($cfg) {
    $smtpServer = $cfg.Email.SmtpHost
    $port = Safe-Int $cfg.Email.SmtpPort 25
    if ([string]::IsNullOrWhiteSpace($smtpServer)) { throw "SMTP Host vuoto." }

    $client = $null
    try {
        $client = New-Object System.Net.Sockets.TcpClient
        $iar = $client.BeginConnect($smtpServer, $port, $null, $null)
        $ok = $iar.AsyncWaitHandle.WaitOne(3000, $false)

        if (-not $ok) {
            try { $client.Close() } catch { }
            return [pscustomobject]@{ Ok = $false; Detail = "Timeout connessione TCP verso $($smtpServer):$port" }
        }

        try {
            $client.EndConnect($iar)
            return [pscustomobject]@{ Ok = $true; Detail = "Connessione TCP riuscita verso $($smtpServer):$port" }
        } catch {
            return [pscustomobject]@{ Ok = $false; Detail = "Connessione TCP fallita verso $($smtpServer):$port - $($_.Exception.Message)" }
        }
    } finally {
        if ($client) {
            try { $client.Close() } catch { }
        }
    }
}

