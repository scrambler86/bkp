            $lblMsg.Text          = "Prima installazione -- configura e clicca Installa."
            $lblMsg.ForeColor     = [System.Drawing.Color]::DarkGreen
        } elseif ($installedVer -ne $currentVer) {
            $btnInstall.Text      = 'Reinstalla'
            $btnInstall.BackColor = [System.Drawing.Color]::FromArgb(255,200,0)
            $lblMsg.Text          = "Versione installata: $installedVer  --  Versione corrente: $currentVer  --  clicca Reinstalla."
            $lblMsg.ForeColor     = [System.Drawing.Color]::DarkOrange
        } else {
            $btnInstall.Text      = 'Reinstalla'
            $btnInstall.BackColor = [System.Drawing.SystemColors]::Control
            if ([string]::IsNullOrWhiteSpace($lblMsg.Text) -or $lblMsg.Text -match 'Versione') {
                $lblMsg.Text = ''
            }
        }
    }

    $btnSetup.Add_Click({
        try { Run-SetupForm; RefreshStatus }
        catch { Msg "ERRORE Setup: $($_.Exception.Message)" $true }
    })

   $btnInstall.Add_Click({
        try {
            Write-BkpScript
            RefreshStatus
            Msg '+ bkp.ps1 installato correttamente.'
        } catch { Msg "ERRORE: $($_.Exception.Message)" $true }
    })
    $btnRemove.Add_Click({
        try {
            $c = Load-Config
            $ok = Remove-AutomationTasks $c
            RefreshStatus
            if ($ok) { Msg '- Automazione rimossa.' }
            else     { Msg '- Rimozione parziale: controlla Task Scheduler.' $true }
        } catch { Msg "ERRORE: $($_.Exception.Message)" $true }
    })
    $btnClose.Add_Click({ $form.Close() })

    $btnLog.Add_Click({
        $logPath = $script:DiagLogPath
        if ([string]::IsNullOrWhiteSpace($logPath) -or -not (Test-Path $logPath)) {
            [System.Windows.Forms.MessageBox]::Show(
                "Nessun log trovato in:`n$logPath`n`nIl log viene creato al primo avvio dei task automatici (RunEvent o RunDailyCheck).",
                'Log Debug','OK','Information') | Out-Null
        } else {
            try { Start-Process 'notepad.exe' -ArgumentList $logPath } catch {
                [System.Windows.Forms.MessageBox]::Show("Impossibile aprire il log: $($_.Exception.Message)", 'Errore','OK','Error') | Out-Null
            }
        }
    })

    $btnCheck.Add_Click({
        try {
            Msg 'Esecuzione check in corso...'
            $c = Load-Config
            $state = Get-BackupState $c
            $state = Evaluate-MissingBackup $c $state
            $col = switch ($state.Status) {
                'OK'      { [System.Drawing.Color]::FromArgb(0,120,0) }
                'MISSING' { [System.Drawing.Color]::DarkOrange }
                'FAIL'    { [System.Drawing.Color]::Red }
                default   { [System.Drawing.Color]::FromArgb(80,80,80) }
            }
            $lblMsg.ForeColor = $col
            $checkMsg = $state.Message
            if ($checkMsg.Length -gt 100) { $checkMsg = $checkMsg.Substring(0, 97) + '...' }
            $lblMsg.Text = "Stato: $($state.Status) -- $checkMsg" 
            Write-DiagLog ("ManualCheck: Status={0} Msg={1}" -f $state.Status, $state.Message) 'INFO'
        } catch {
            Msg "ERRORE check: $($_.Exception.Message)" $true
        }
    })

    RefreshStatus
    [void]$form.ShowDialog()
}

Run-MainForm
