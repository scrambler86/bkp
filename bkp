function Get-BkpInstalledVersion([string]$bkpPath) {
    # Legge la versione dal bkp.ps1 installato cercando la riga $script:BKP_VERSION
    try {
        if (-not (Test-Path $bkpPath)) { return $null }
        $line = Get-Content $bkpPath | Select-String "BKP_VERSION\s*=\s*'([^']+)'" | Select-Object -First 1
        if ($line -and $line.Matches.Count -gt 0) {
            return $line.Matches[0].Groups[1].Value
        }
    } catch { }
    return $null
}

function Write-BkpScript {
    Ensure-Dir $ConfigDir
    $dest = Join-Path $ConfigDir 'bkp.ps1'
    # Prova prima con il Base64 embedded (funziona sia da .exe che da .ps1 precompilato)
    if (-not [string]::IsNullOrWhiteSpace($script:BKP_EMBEDDED_PS1) -and
        $script:BKP_EMBEDDED_PS1 -ne 'PLACEHOLDER_BASE64') {
        try {
            $bytes = [Convert]::FromBase64String($script:BKP_EMBEDDED_PS1)
            [System.IO.File]::WriteAllBytes($dest, $bytes)
            Write-DiagLog "Write-BkpScript: scritto da Base64 embedded -> $dest"
            Set-FileAclToSystemAndAdmins $dest
            try { (Get-Item $dest).Attributes = [System.IO.FileAttributes]::Hidden -bor [System.IO.FileAttributes]::System } catch { }
            return
        } catch {
            Write-DiagLog "Write-BkpScript: fallback da Base64 fallito: $($_.Exception.Message)" 'WARN'
        }
    }
    # Fallback: copia se stesso (funziona solo quando eseguito come .ps1)
    $src = Get-SelfScriptPath
    if (-not [string]::IsNullOrWhiteSpace($src) -and (Test-Path $src)) {
        try {
            Copy-Item -Path $src -Destination $dest -Force
            Write-DiagLog "Write-BkpScript: copiato da $src -> $dest"
            Set-FileAclToSystemAndAdmins $dest
            try { (Get-Item $dest).Attributes = 'Hidden' } catch { }
            return
        } catch {
            Write-DiagLog "Write-BkpScript: copia file fallita: $($_.Exception.Message)" 'WARN'
        }
    }
    throw "Write-BkpScript: impossibile scrivere bkp.ps1 (né Base64 né file sorgente disponibili)"
}
   
}
function Install-AutomationTasks($cfg) {
    $cfg = Load-Config

    # ── FASE 1: valida tutto prima di toccare i task esistenti ──────────────
    # Nessuna modifica al sistema finche non siamo sicuri che tutto e ok.

    # Scrivi/aggiorna bkp.ps1 in ProgramData\BackupMonitor (accessibile da SYSTEM, no permessi speciali)
    $bkpTargetPath = Join-Path $env:ProgramData 'BackupMonitor\bkp.ps1'
    try {
        Write-BkpScript
    } catch {
        throw "Impossibile scrivere bkp.ps1 in $bkpTargetPath : $($_.Exception.Message)"
    }

    $resolvedLogName = Resolve-PrimaryEventLogForMode $cfg
    if ([string]::IsNullOrWhiteSpace($resolvedLogName)) {
        $bm = Normalize-BackupMode ([string]$cfg.BackupMode)
        $hint = switch ($bm) {
            'FileHistory' { 'Event Viewer > Registri applicazioni e servizi > Microsoft > Windows > FileHistory-Engine > BackupLog' }
            'WSB'         { 'Event Viewer > Registri applicazioni e servizi > Microsoft > Windows > Backup (o Backup/Operational)' }
            'Legacy'      { 'Event Viewer > Registri applicazioni e servizi > Microsoft > Windows > Backup (o Backup/Operational)' }
            default       { 'Event Viewer > Registri applicazioni e servizi > Microsoft > Windows > Backup / FileHistory-Engine' }
        }
        throw "Impossibile trovare un registro eventi valido per la modalità selezionata ($bm). Verifica: $hint"
    }

    $eventTask = $cfg.Tasks.EventTaskName -replace '[^\w]', '_'
    $dailyTask = $cfg.Tasks.DailyTaskName -replace '[^\w]', '_'

    if ([string]::IsNullOrWhiteSpace($eventTask)) { throw "EventTaskName non valido nella config." }
    if ([string]::IsNullOrWhiteSpace($dailyTask))  { throw "DailyTaskName non valido nella config." }

    # Valida orario DAILY se abilitato (meglio scoprirlo ora che dopo la rimozione)
    if ([bool]$cfg.DailyCheckEnabled) {
        $atValidation = Normalize-ScheduleTimeLoose $cfg.DailyCheckTime '09:30'
        if ([string]::IsNullOrWhiteSpace($atValidation)) { throw "Orario DailyCheckTime non valido: $($cfg.DailyCheckTime)" }
    }

    if ($cfg.EventLogName -ne $resolvedLogName) {
        $cfg.EventLogName = $resolvedLogName
        try { Save-Config $cfg } catch { }
    }

    # ── FASE 2: rimuovi vecchi task (solo dopo validazione ok) ──────────────
    $removedOk = Remove-AutomationTasks $cfg
    if (-not $removedOk) {
        throw "Impossibile rimuovere completamente i task precedenti. Installazione annullata per evitare task orfani. Rimuovi manualmente i task dal Task Scheduler e riprova."
    }

    # ── FASE 3: installa nuovi task ──────────────────────────────────────────

    $principal = New-ScheduledTaskPrincipal -UserId 'SYSTEM' -LogonType ServiceAccount -RunLevel Highest
    $settings  = New-ScheduledTaskSettingsSet -StartWhenAvailable -MultipleInstances IgnoreNew -ExecutionTimeLimit (New-TimeSpan -Minutes 15)

    $actionEvent = New-ScheduledTaskAction -Execute 'powershell.exe' -Argument "-NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File `"$bkpTargetPath`" -RunEvent"

    # FIX: tutta la fase EVENT in try/catch con rollback completo.
    # Se qualsiasi passaggio fallisce (Register, Export, XML, re-import),
    # il task EVENT viene rimosso per non lasciare installazione parziale.
    try {
        Register-ScheduledTask -TaskName $eventTask -Action $actionEvent -Principal $principal -Settings $settings -Force -ErrorAction Stop | Out-Null

        $xml = Export-ScheduledTask -TaskName $eventTask -ErrorAction Stop

        # Trigger su QUALSIASI evento del log backup:
        # la logica di filtro la fa poi lo script, cosi intercettiamo anche errori
        # che Windows Server Backup registra con EventID differenti ma con testo di fallimento.
        
# [BOOKMARK:TASK_EVENT_TRIGGER]
# Trigger EVENT basato su BackupMode.
# Per affidabilità usiamo TRIGGER SEPARATI (uno per log) e NON un QueryList multi-log.
$triggers = New-Object System.Collections.Generic.List[string]

function New-EventTriggerXml([string]$logName, [string]$selectExpr) {
    $subscriptionXml = "<QueryList><Query Id='0' Path='$logName'><Select Path='$logName'>$selectExpr</Select></Query></QueryList>"
    $subscriptionEsc = [System.Security.SecurityElement]::Escape($subscriptionXml)
    return "<EventTrigger><Enabled>true</Enabled><Subscription>$subscriptionEsc</Subscription></EventTrigger>"
}

$mode = Normalize-BackupMode ([string]$cfg.BackupMode)

switch ($mode) {
    'FileHistory' {
        # FIX: il log reale degli eventi FileHistory su Win10/11 e' spesso
        # FileHistory-Core/WHC (EventID 201=FAIL) e NON FileHistory-Engine/BackupLog.
        # Registriamo trigger su ENTRAMBI i log per coprire tutte le versioni Windows.
        $fhEngineLog = 'Microsoft-Windows-FileHistory-Engine/BackupLog'
        $fhCoreLog   = 'Microsoft-Windows-FileHistory-Core/WHC'

        if (Test-EventLogExists $fhEngineLog) {
            $triggers.Add((New-EventTriggerXml $fhEngineLog '*[System[(EventID=200 or EventID=201 or EventID=203 or EventID=204)]]')) | Out-Null
        }
        if (Test-EventLogExists $fhCoreLog) {
            # WHC: EventID 200=OK (ciclo completato), 201=FAIL (errore backup)
            $triggers.Add((New-EventTriggerXml $fhCoreLog '*[System[(EventID=200 or EventID=201)]]')) | Out-Null
        }
    }

    default {
        # Log principale (WSB/Legacy/Auto)
        if (-not [string]::IsNullOrWhiteSpace($resolvedLogName) -and (Test-EventLogExists $resolvedLogName)) {
            $sel = '*'
            $fhLogName = 'Microsoft-Windows-FileHistory-Engine/BackupLog'
            if ($resolvedLogName -eq $fhLogName) { $sel = '*[System[(EventID=200 or EventID=201 or EventID=203 or EventID=204)]]' }
            $triggers.Add((New-EventTriggerXml $resolvedLogName $sel)) | Out-Null
        }

        # In AUTO, aggiungi FileHistory-Engine e FileHistory-Core/WHC se MonitorFileHistory=true
        if ($mode -eq 'Auto') {
            $useFH = ($cfg.PSObject.Properties.Match('MonitorFileHistory').Count -gt 0 -and [bool]$cfg.MonitorFileHistory)
            if ($useFH) {
                $fhEngineLog = 'Microsoft-Windows-FileHistory-Engine/BackupLog'
                $fhCoreLog   = 'Microsoft-Windows-FileHistory-Core/WHC'
                if (($fhEngineLog -ne $resolvedLogName) -and (Test-EventLogExists $fhEngineLog)) {
                    $triggers.Add((New-EventTriggerXml $fhEngineLog '*[System[(EventID=200 or EventID=201 or EventID=203 or EventID=204)]]')) | Out-Null
                }
                if (($fhCoreLog -ne $resolvedLogName) -and (Test-EventLogExists $fhCoreLog)) {
                    $triggers.Add((New-EventTriggerXml $fhCoreLog '*[System[(EventID=200 or EventID=201)]]')) | Out-Null
                }
            }
        }
    }
}

if ($triggers.Count -eq 0) {
    # Fallback: nessun log trovato (PC nuovo senza backup mai avviato).
    # Usa log Application come trigger placeholder -- il task esiste ma non sparerà
    # finché non viene configurato un backup reale.
    Write-DiagLog "Install-AutomationTasks: nessun log backup trovato, uso fallback Application log" 'WARN'
    $triggers.Add((New-EventTriggerXml 'Application' '*[System[(Level=2) and (EventID=0)]]')) | Out-Null
}
$eventTrigger = ($triggers -join '')



        if ($xml -match '<Triggers\s*/>') {
            $xml = $xml -replace '<Triggers\s*/>', "<Triggers>$eventTrigger</Triggers>"
        } elseif ($xml -match '<Triggers>') {
            $xml = $xml -replace '<Triggers>', "<Triggers>$eventTrigger"
        } else {
            $xml = $xml -replace '</RegistrationInfo>', "</RegistrationInfo><Triggers>$eventTrigger</Triggers>"
        }

        $tmp = Join-Path $env:TEMP 'task_event.xml'
        [System.IO.File]::WriteAllText($tmp, $xml, [System.Text.Encoding]::Unicode)
        Write-DiagLog "task_event.xml scritto in: $tmp" 'INFO'
        try {
            $result = & schtasks.exe /Create /TN $eventTask /XML $tmp /F 2>&1
            if ($LASTEXITCODE -ne 0) {
                throw "schtasks /Create XML fallito (exit $LASTEXITCODE): $result"
            }
            Write-DiagLog "Task EVENT creato via schtasks XML: $result" 'INFO'
        } catch {
            Write-DiagLog "XML task EVENT: $xml" 'ERROR'
            throw
        }
    } catch {
        # Rollback: rimuovi EVENT parzialmente creato
        Remove-TaskSafe $eventTask
        throw "Creazione task EVENT fallita: $($_.Exception.Message). Rollback eseguito."
    }

    Prime-TriggerRuntimeState $cfg

    if ([bool]$cfg.DailyCheckEnabled) {
        $at = Normalize-ScheduleTimeLoose $cfg.DailyCheckTime '09:30'

        $scheduleFrequency = ([string]$cfg.ScheduleFrequency).Trim()
        if ($scheduleFrequency -notin @('Daily','Weekly','Monthly')) { $scheduleFrequency = 'Daily' }

        Remove-TaskSafe $dailyTask

        $taskCmd = "powershell.exe -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File `"$bkpTargetPath`" -RunDailyCheck"

        $args = @('/Create','/F','/TN',$dailyTask,'/TR',$taskCmd,'/RU','SYSTEM','/RL','HIGHEST','/SC')
        switch ($scheduleFrequency) {
            'Weekly' {
                $args += @('WEEKLY','/D','MON','/ST',$at)
            }
            'Monthly' {
                $args += @('MONTHLY','/D','1','/ST',$at)
            }
            default {
                $args += @('DAILY','/ST',$at)
            }
        }

        $null = & schtasks.exe @args 2>&1
        if ($LASTEXITCODE -ne 0) {
            # Rollback completo: rimuovi sia DAILY (potenzialmente parziale) che EVENT
            Remove-TaskSafe $dailyTask
            Remove-TaskSafe $eventTask
            throw "Creazione task DAILY fallita (schtasks exit code: $LASTEXITCODE). Orario richiesto: $at. Rollback completo eseguito."
        }
    } else {
        Remove-TaskSafe $dailyTask
    }

    # FIX: salva InstalledTaskNames SOLO ora, quando tutta l'installazione e riuscita.
    # Non prima: se EVENT o DAILY fallivano, si salvava un riferimento a task non esistenti.
    try {
        $cfgSaved = Load-Config
        Set-OrAddProp $cfgSaved 'InstalledTaskNames' ([pscustomobject]@{
            EventTaskName = $eventTask
            DailyTaskName = $dailyTask
        })
        Save-Config $cfgSaved
    } catch { }
}

function Remove-AutomationTasks($cfg) {
    $toRemove = New-Object System.Collections.Generic.List[string]
    if ($cfg.PSObject.Properties.Match('InstalledTaskNames').Count -gt 0 -and $cfg.InstalledTaskNames) {
        $itn = $cfg.InstalledTaskNames
        if ($itn.PSObject.Properties.Match('EventTaskName').Count -gt 0 -and $itn.EventTaskName) { $toRemove.Add([string]$itn.EventTaskName) }
        if ($itn.PSObject.Properties.Match('DailyTaskName').Count -gt 0 -and $itn.DailyTaskName) { $toRemove.Add([string]$itn.DailyTaskName) }
    }
    $toRemove.Add(("Monitor_Backup_$($cfg.BackupName)_EVENT" -replace '[^\w]','_'))
    $toRemove.Add(("Monitor_Backup_$($cfg.BackupName)_DAILY" -replace '[^\w]','_'))

    $allRemoved = $true
    foreach ($n in ($toRemove | Select-Object -Unique)) {
        $sanitized = $n -replace '[^\w]','_'
        if (Get-TaskInstalled $sanitized) {
            # Prova prima Unregister-ScheduledTask, fallback su schtasks.exe
            $removed = $false
            try {
                Unregister-ScheduledTask -TaskName $sanitized -Confirm:$false -ErrorAction Stop | Out-Null
                $removed = $true
            } catch {
                $null = & schtasks.exe /Delete /TN $sanitized /F 2>&1
                $removed = ($LASTEXITCODE -eq 0)
            }
            if (-not $removed) { $allRemoved = $false }
        }
    }

    if ($allRemoved) {
        try {
            $saved = Load-Config
            if ($saved.PSObject.Properties.Match('InstalledTaskNames').Count -gt 0) {
                $saved.InstalledTaskNames = $null
                Save-Config $saved
            }
        } catch { }
    }
    return $allRemoved
}

function Get-TaskInstalled([string]$taskName) {
    $sanitized = $taskName -replace '[^\w]', '_'
    try {
        [void](Get-ScheduledTask -TaskName $sanitized -ErrorAction Stop)
        return $true
    } catch {
        # Fallback: Get-ScheduledTask non disponibile (WMI rotto su alcuni Win11)
        try {
            $null = & schtasks.exe /Query /TN $sanitized 2>&1
            return ($LASTEXITCODE -eq 0)
        } catch {
            return $false
        }
    }
}

# [BOOKMARK:ENTRYPOINT]
$cfg = Load-Config
[void](Get-OrCreate-SecretKeyBytes)

if ($PrepareForCompile) {
    $selfPath = Get-SelfScriptPath
    if ([string]::IsNullOrWhiteSpace($selfPath) -or -not (Test-Path $selfPath)) {
        Write-Host "ERRORE: impossibile trovare il file script corrente." -ForegroundColor Red
        exit 1
    }
    Write-Host "Lettura script da: $selfPath" -ForegroundColor Cyan
    $bytes  = [System.IO.File]::ReadAllBytes($selfPath)
    $b64    = [Convert]::ToBase64String($bytes)

    $content = [System.IO.File]::ReadAllText($selfPath, [System.Text.Encoding]::UTF8)
    $newContent = $content -replace `
        "(\`$script:BKP_EMBEDDED_PS1\s*=\s*')[^']*(')", `
        "`${1}$b64`${2}"

    [System.IO.File]::WriteAllText($selfPath, $newContent, [System.Text.Encoding]::UTF8)
    Write-Host "OK: BKP_EMBEDDED_PS1 aggiornato. Ora puoi compilare con ps2exe." -ForegroundColor Green
    exit 0
}

if ($Setup) { Run-SetupForm; exit 0 }

if ($InstallAutomation) {
    Install-AutomationTasks $cfg
    exit 0
}

if ($RemoveAutomation) {
    [void](Remove-AutomationTasks $cfg)
    exit 0
}

if ($TestAll -or $TestEmail -or $TestDiscord) {
    $tmp = Load-Config
    if ($TestEmail)   { $tmp.NotifyMode = 'Email' }
    if ($TestDiscord) { $tmp.NotifyMode = 'Discord'; $tmp.Discord.Enabled = $true }
    if ($TestAll)     { $tmp.NotifyMode = 'Both';    $tmp.Discord.Enabled = $true }
    $st = [pscustomobject]@{ Status='FAIL'; Message='TEST: notifica'; LastSuccessEvent=$null; LastFailureEvent=$null }
    Notify -cfg $tmp -state $st -reasonTag 'TEST' -Force
    exit 0
}

if ($RunEvent) {
    Write-DiagSep 'RunEvent START'
    Write-DiagLog ("BackupMode={0}  BackupName={1}" -f $cfg.BackupMode, $cfg.BackupName)
    Touch-LastRun 'EVENT'
    try {
        $triggerLogs = @(Get-TriggerEventLogNames $cfg)
        if ($triggerLogs.Count -eq 0) {
            Write-DiagLog 'NESSUN log trigger trovato/disponibile sul sistema' 'WARN'
        } else {
            foreach ($tl in $triggerLogs) {
                Write-DiagLog ("Log trigger: {0}" -f $tl)
            }
        }

        $eventStates = @(Get-NewTriggerEventStates $cfg)
        Write-DiagLog ("Nuovi eventi classificati: {0}" -f $eventStates.Count)

        $sent = 0
        foreach ($state in $eventStates) {
            $shouldNotify = Should-Notify-Event $cfg $state
            Write-DiagLog ("Evento: Status={0}  Notify={1}  Msg={2}" -f $state.Status, $shouldNotify, $state.Message)
            if ($shouldNotify) {
                $sent++
                try {
                    Notify -cfg $cfg -state $state -reasonTag 'EVENT_TRIGGER'
                    Write-DiagLog ("Notifica inviata (evento #{0})" -f $sent) 'OK'
                    if ($state.Status -eq 'FAIL') { Save-LastFailNotifyTime }
                } catch {
                    Write-DiagLog ("Errore invio notifica: {0}" -f $_.Exception.Message) 'ERROR'
                }
            }
        }
        Write-DiagLog ("RunEvent END: eventi={0} notifiche={1}" -f $eventStates.Count, $sent)
    } catch {
        Write-DiagLog ("RunEvent EXCEPTION: {0}" -f $_.Exception.Message) 'ERROR'
        Write-DiagLog ($_.ScriptStackTrace) 'ERROR'
    }
    exit 0
}

if ($RunDailyCheck) {
    Write-DiagSep 'RunDaily START'
    Write-DiagLog ("BackupMode={0}  BackupName={1}  DailyEnabled={2}" -f $cfg.BackupMode, $cfg.BackupName, $cfg.DailyCheckEnabled)
    Touch-LastRun 'DAILY'
    try {
        if (-not [bool]$cfg.DailyCheckEnabled) {
            Write-DiagLog 'DailyCheck disabilitato nella config -- uscita.'
            exit 0
        }

        $state = Get-BackupState $cfg
        Write-DiagLog ("BackupState: Status={0}  Msg={1}" -f $state.Status, $state.Message)

        if ($state.LastSuccessEvent) {
            $age = [math]::Round(((Get-Date) - $state.LastSuccessEvent.TimeCreated).TotalHours, 1)
            Write-DiagLog ("Ultimo successo: {0} ({1} ore fa)" -f $state.LastSuccessEvent.TimeCreated.ToString('yyyy-MM-dd HH:mm'), $age)
        } else {
            Write-DiagLog 'Nessun evento di successo trovato nei log' 'WARN'
        }

        $state = Evaluate-MissingBackup $cfg $state
        Write-DiagLog ("Dopo Evaluate: Status={0}  Soglia={1}h" -f $state.Status, $cfg.MissingIfSuccessOlderThanHours)

        $shouldNotify = Should-Notify-Daily $cfg $state
        Write-DiagLog ("Should-Notify-Daily={0}  DailyNotifyMode={1}" -f $shouldNotify, $cfg.DailyNotifyMode)

        if ($shouldNotify) {
            try {
                Notify -cfg $cfg -state $state -reasonTag 'DAILY_CHECK'
                Write-DiagLog ("RunDaily END status={0} (NOTIFIED)" -f $state.Status) 'OK'
            } catch {
                Write-DiagLog ("RunDaily errore invio notifica: {0}" -f $_.Exception.Message) 'ERROR'
            }
        } else {
            Write-DiagLog ("RunDaily END status={0} (NO_NOTIFY)" -f $state.Status)
        }
    } catch {
        Write-DiagLog ("RunDaily EXCEPTION: {0}" -f $_.Exception.Message) 'ERROR'
        Write-DiagLog ($_.ScriptStackTrace) 'ERROR'
    }
    exit 0
}

