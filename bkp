    # ---------- Save/apply ----------
    function Apply-And-Save([switch]$Silent) {
        $tmp = Load-Config
        $prev = ($tmp | ConvertTo-Json -Depth 12) | ConvertFrom-Json

        $tmp.BackupName = $tbBackupName.Text.Trim()
        $tmp.NotifyMode = [string]$cbMode.SelectedItem

        # BackupMode (Auto/WSB/FileHistory/Legacy)
        $modeCode = Get-BackupModeCodeFromUi ([string]$cbBackupMode.SelectedItem)
        Set-OrAddProp $tmp 'BackupMode' $modeCode

        Set-OrAddProp $tmp 'SendOnSuccessEvent' $chkSendOnSuccess.Checked
        Set-OrAddProp $tmp 'DailyCheckEnabled'  $chkDailyEnabled.Checked
        Set-OrAddProp $tmp 'DailyNotifyMode'    ([string]$cbDailyMode.SelectedItem)
        Set-OrAddProp $tmp 'MissingIfSuccessOlderThanHours' (Safe-Int $tbMissing.Text 26)
        Set-OrAddProp $tmp 'DailyCheckTime' (Get-TimePickerValue $tpDailyTime)
        Set-OrAddProp $tmp 'ScheduleFrequency' ([string]$cbScheduleFrequency.SelectedItem)
        # MonitorFileHistory viene vincolato dalla modalità:
        # - FileHistory: sempre ON
        # - WSB/Legacy : sempre OFF
        # - Auto       : usa la spunta dell'utente
        switch ($modeCode) {
            'FileHistory' { Set-OrAddProp $tmp 'MonitorFileHistory' $true }
            'WSB'         { Set-OrAddProp $tmp 'MonitorFileHistory' $false }
            'Legacy'      { Set-OrAddProp $tmp 'MonitorFileHistory' $false }
            default       { Set-OrAddProp $tmp 'MonitorFileHistory' $chkMonitorFH.Checked }
        }
        $cooldownSave = if ($chkCooldown.Checked) { 30 } else { 0 }
        Set-OrAddProp $tmp 'EventCooldownMinutes' $cooldownSave
        Set-OrAddProp $tmp 'FileHistoryDataPath' $tbFHPath.Text.Trim()

        Ensure-SubObject $tmp 'Email' (Get-DefaultConfig).Email
        $tmp.Email.SmtpHost = $tbHost.Text.Trim()
        $tmp.Email.SmtpPort = (Safe-Int $tbPort.Text 25)
        $tmp.Email.UseSsl   = $chkSsl.Checked
        $tmp.Email.From     = $tbFrom.Text.Trim()
        $tmp.Email.To       = $tbTo.Text.Trim()
        $tmp.Email.Cc       = $tbCc.Text.Trim()
        $tmp.Email.SubjectPrefix = $tbPrefix.Text.Trim()
        $tmp.Email.UseAuth  = $chkAuth.Checked
        $tmp.Email.Username = $tbUser.Text.Trim()

        if ($tmp.Email.UseAuth -and $tbPass.Text.Trim()) {
            $tmp.Email.PasswordProtected = Protect-Secret ($tbPass.Text.Trim())
        }

        Ensure-SubObject $tmp 'Discord' (Get-DefaultConfig).Discord
        $tmp.Discord.Enabled = $chkDis.Checked
        if ($tmp.Discord.Enabled -and $tbWh.Text.Trim()) {
            $tmp.Discord.WebhookProtected = Protect-Secret ($tbWh.Text.Trim())
        }

        $tmp = Normalize-Config $tmp
        Validate-ConfigOrThrow $tmp

        # Ensure secret key exists (used to protect SMTP password / Discord webhook)
        [void](Get-OrCreate-SecretKeyBytes)

        Save-Config $tmp
        $script:dirty = $false

       # Reinstalla i task SOLO se serve (evita finestre "di buco" e perdita eventi durante i test).
        # Serve reinstallare solo quando cambiano trigger/nome task/schedule.
        $needReinstall = $false

        try {
            # Task installati?
            $prevNames = $null
            if ($prev.PSObject.Properties.Match('InstalledTaskNames').Count -gt 0 -and $prev.InstalledTaskNames) {
                $prevNames = $prev.InstalledTaskNames
            }

            # Reinstalla automaticamente SOLO se i task erano già installati in precedenza.
            # Al primo avvio (nessun InstalledTaskNames) l'utente deve usare il pulsante Installa.
            $wereInstalled = ($prevNames -ne $null)

            if ($wereInstalled) {
                $prevEventTask = if ($prevNames.PSObject.Properties.Match('EventTaskName').Count -gt 0) { [string]$prevNames.EventTaskName } else { "Monitor_Backup_$($prev.BackupName)_EVENT" }
                $prevDailyTask = if ($prevNames.PSObject.Properties.Match('DailyTaskName').Count -gt 0) { [string]$prevNames.DailyTaskName } else { "Monitor_Backup_$($prev.BackupName)_DAILY" }

                if (-not (Get-TaskInstalled $prevEventTask)) { $needReinstall = $true }
                if ([bool]$tmp.DailyCheckEnabled -and (-not (Get-TaskInstalled $prevDailyTask))) { $needReinstall = $true }
            }

            # Cambi che impattano i trigger o la schedule (solo se già installati)
            if ($wereInstalled) {
                if ([string]$prev.BackupName -ne [string]$tmp.BackupName) { $needReinstall = $true }
                if ([string]$prev.BackupMode -ne [string]$tmp.BackupMode) { $needReinstall = $true }
                if ([bool]$prev.DailyCheckEnabled -ne [bool]$tmp.DailyCheckEnabled) { $needReinstall = $true }
                if ([string]$prev.DailyCheckTime -ne [string]$tmp.DailyCheckTime) { $needReinstall = $true }
                if ([string]$prev.ScheduleFrequency -ne [string]$tmp.ScheduleFrequency) { $needReinstall = $true }
                if ((Normalize-BackupMode ([string]$tmp.BackupMode)) -eq 'Auto') {
                    if ([bool]$prev.MonitorFileHistory -ne [bool]$tmp.MonitorFileHistory) { $needReinstall = $true }
                }
            }
        } catch {
            # Se non riusciamo a determinare e i task erano installati, meglio reinstallare
            $needReinstall = $wereInstalled
        }

        if ($needReinstall) {
            try {
                Install-AutomationTasks $tmp
                $autoReinstallMsg = " Task aggiornati automaticamente."
            } catch {
                $autoReinstallMsg = "`nATTENZIONE: salvataggio ok ma reinstallo task fallito: $($_.Exception.Message)"
            }
        } else {
            $autoReinstallMsg = " Task NON reinstallati (non necessario)."
        }

        if (-not $Silent) {
            [System.Windows.Forms.MessageBox]::Show(
                "Configurazione salvata in:`n$ConfigPath`n`nChiave segreti in:`n$SecretKeyPath`n`n$autoReinstallMsg",
                'OK','OK','Information'
            ) | Out-Null
        }
    }

