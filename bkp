function ConvertTo-Base64Lines([byte[]]$bytes) {
    $b64 = [Convert]::ToBase64String($bytes)
    # Wrap at 76 chars per RFC
    $lines = New-Object System.Collections.Generic.List[string]
    for ($i = 0; $i -lt $b64.Length; $i += 76) {
        $len = [Math]::Min(76, $b64.Length - $i)
        $lines.Add($b64.Substring($i, $len))
    }
    return ($lines -join "`r`n")
}

function Encode-SubjectUtf8([string]$subject) {
    if ([string]::IsNullOrWhiteSpace($subject)) { return "" }

    # Se ASCII puro, non forzare l'encoding MIME (evita subject tipo =?utf-8?B?...?= su alcuni client)
    if ($subject -notmatch '[^\x00-\x7F]') { return $subject }

    $bytes = [System.Text.Encoding]::UTF8.GetBytes($subject)
    $b64 = [Convert]::ToBase64String($bytes)
    return "=?utf-8?B?$b64?="
}
function Parse-AddressList([string]$s) {
    $list = New-Object System.Collections.Generic.List[string]
    if ([string]::IsNullOrWhiteSpace($s)) { return $list }
    foreach ($p in ($s -split ';')) {
        $t = $p.Trim()
        if (-not [string]::IsNullOrWhiteSpace($t)) { $list.Add($t) }
    }
    return $list
}

function Build-RawMimeMessage([string]$from, [string]$toCsv, [string]$ccCsv, [string]$subject, [string]$plainBody, [string]$htmlBody) {
    $boundary = "bm_" + ([Guid]::NewGuid().ToString("N"))
    $date = (Get-Date).ToString("r")

    $plainB64 = ConvertTo-Base64Lines ([System.Text.Encoding]::UTF8.GetBytes($plainBody))
    $htmlB64  = ConvertTo-Base64Lines ([System.Text.Encoding]::UTF8.GetBytes($htmlBody))
    $subEnc   = Encode-SubjectUtf8 $subject

    $headers = New-Object System.Collections.Generic.List[string]
    $headers.Add("From: $from")
    if ($toCsv) { $headers.Add("To: $toCsv") }
    if ($ccCsv) { $headers.Add("Cc: $ccCsv") }
    $headers.Add("Subject: $subEnc")
    $headers.Add("Date: $date")
    $headers.Add("MIME-Version: 1.0")
    $headers.Add("Content-Type: multipart/alternative; boundary=`"$boundary`"")
    $headers.Add("") # blank line before body

    $body = New-Object System.Collections.Generic.List[string]
    $body.Add("--$boundary")
    $body.Add("Content-Type: text/plain; charset=`"utf-8`"")
    $body.Add("Content-Transfer-Encoding: base64")
    $body.Add("")
    $body.Add($plainB64)
    $body.Add("")
    $body.Add("--$boundary")
    $body.Add("Content-Type: text/html; charset=`"utf-8`"")
    $body.Add("Content-Transfer-Encoding: base64")
    $body.Add("")
    $body.Add($htmlB64)
    $body.Add("")
    $body.Add("--$boundary--")
    $body.Add("")

    return (($headers + $body) -join "`r`n")
}

function Read-SmtpResponse([System.IO.StreamReader]$reader) {
    # Reads single or multi-line response. Returns: @{ Code=int; Lines=string[]; Raw=string }
    $lines = New-Object System.Collections.Generic.List[string]
    $first = $reader.ReadLine()
    if ($null -eq $first) { throw "Connessione SMTP chiusa dal server." }
    $lines.Add($first)

    if ($first.Length -ge 4) {
        $code = 0
        [void][int]::TryParse($first.Substring(0,3), [ref]$code)
        $isMulti = ($first[3] -eq '-')
        if ($isMulti) {
            while ($true) {
                $l = $reader.ReadLine()
                if ($null -eq $l) { break }
                $lines.Add($l)
                if ($l.Length -ge 4 -and $l.Substring(0,3) -eq $first.Substring(0,3) -and $l[3] -ne '-') { break }
            }
        }
        return @{ Code = $code; Lines = $lines.ToArray(); Raw = ($lines -join "`n") }
    }

    return @{ Code = 0; Lines = $lines.ToArray(); Raw = ($lines -join "`n") }
}

function Send-SmtpLine([System.IO.StreamWriter]$writer, [string]$line) {
    $writer.WriteLine($line)
    $writer.Flush()
}

function Expect-Code($resp, [int[]]$codes, [string]$context) {
    if (-not ($codes -contains [int]$resp.Code)) {
        throw ("SMTP errore in {0}. Atteso: {1}. Ricevuto: {2}`n{3}" -f $context, ($codes -join ','), $resp.Code, $resp.Raw)
    }
}

function Send-Email-ImplicitTLS(
    [string]$smtpServer,
    [int]$smtpPort,
    [bool]$useAuth,
    [string]$username,
    [string]$password,
    [string]$from,
    [System.Collections.Generic.List[string]]$toList,
    [System.Collections.Generic.List[string]]$ccList,
    [string]$subject,
    [string]$plainBody,
    [string]$htmlBody
) {
    $tcp = New-Object System.Net.Sockets.TcpClient
    $tcp.SendTimeout = 15000
    $tcp.ReceiveTimeout = 15000
    $tcp.Connect($smtpServer, $smtpPort)


    if ($null -eq $toList) { $toList = New-Object System.Collections.Generic.List[string] }
    if ($null -eq $ccList) { $ccList = New-Object System.Collections.Generic.List[string] }
        $ssl = New-Object System.Net.Security.SslStream($tcp.GetStream(), $false)

    # Forza TLS 1.2 (molti SMTP moderni rifiutano TLS 1.0/1.1 e, su alcune macchine,
    # lo "SystemDefault" di SslStream può fallire con errore SSPI).
    $handshakeOk = $false
    $lastHsErr = $null

    try {
        $proto = [System.Security.Authentication.SslProtocols]::Tls12
        $ssl.AuthenticateAsClient($smtpServer, $null, $proto, $false)
        $handshakeOk = $true
    } catch {
        $lastHsErr = $_.Exception
    }

    if (-not $handshakeOk) {
        # Fallback: ritenta con i protocolli di default riaprendo la connessione.
        try { $ssl.Close() } catch { }
        try { $tcp.Close() } catch { }

        $tcp = New-Object System.Net.Sockets.TcpClient
        $tcp.SendTimeout = 15000
        $tcp.ReceiveTimeout = 15000
        $tcp.Connect($smtpServer, $smtpPort)

        $ssl = New-Object System.Net.Security.SslStream($tcp.GetStream(), $false)
        try {
            $ssl.AuthenticateAsClient($smtpServer)
            $handshakeOk = $true
        } catch {
            $lastHsErr = $_.Exception
        }
    }

    if (-not $handshakeOk) {
        try { $tcp.Close() } catch { }
        $msg = if ($lastHsErr) { $lastHsErr.Message } else { "Handshake TLS fallita." }
        throw ("TLS handshake fallita su {0}:{1} - {2}" -f $smtpServer, $smtpPort, $msg)
    }

$reader = New-Object System.IO.StreamReader($ssl, [System.Text.Encoding]::ASCII)
    $writer = New-Object System.IO.StreamWriter($ssl, [System.Text.Encoding]::ASCII)
    $writer.NewLine = "`r`n"
    $writer.AutoFlush = $true

    $resp = Read-SmtpResponse $reader
    Expect-Code $resp @(220) "GREETING"

    $ehloName = $env:COMPUTERNAME
    if ([string]::IsNullOrWhiteSpace($ehloName)) { $ehloName = "localhost" }
    Send-SmtpLine $writer ("EHLO " + $ehloName)
    $resp = Read-SmtpResponse $reader
    Expect-Code $resp @(250) "EHLO"

    if ($useAuth) {
        if ([string]::IsNullOrWhiteSpace($username) -or [string]::IsNullOrWhiteSpace($password)) {
            throw "SMTP login attivo ma Username/Password mancanti."
        }

        Send-SmtpLine $writer "AUTH LOGIN"
        $resp = Read-SmtpResponse $reader
        Expect-Code $resp @(334) "AUTH LOGIN (step 1)"

        Send-SmtpLine $writer ([Convert]::ToBase64String([System.Text.Encoding]::ASCII.GetBytes($username)))
        $resp = Read-SmtpResponse $reader
        Expect-Code $resp @(334) "AUTH LOGIN (username)"

        Send-SmtpLine $writer ([Convert]::ToBase64String([System.Text.Encoding]::ASCII.GetBytes($password)))
        $resp = Read-SmtpResponse $reader
        Expect-Code $resp @(235) "AUTH LOGIN (password)"
    }

    Send-SmtpLine $writer ("MAIL FROM:<{0}>" -f $from)
    $resp = Read-SmtpResponse $reader
    Expect-Code $resp @(250) "MAIL FROM"

    $allRcpt = New-Object System.Collections.Generic.List[string]
    foreach ($a in $toList) { $allRcpt.Add($a) }
    foreach ($a in $ccList) { $allRcpt.Add($a) }

    if ($allRcpt.Count -eq 0) { throw "Destinatari vuoti (To/Cc)." }

    foreach ($rcpt in $allRcpt) {
        Send-SmtpLine $writer ("RCPT TO:<{0}>" -f $rcpt)
        $resp = Read-SmtpResponse $reader
        Expect-Code $resp @(250,251) ("RCPT TO " + $rcpt)
    }

    Send-SmtpLine $writer "DATA"
    $resp = Read-SmtpResponse $reader
    Expect-Code $resp @(354) "DATA"

    $toCsv = ($toList.ToArray() -join ", ")
    $ccCsv = ($ccList.ToArray() -join ", ")
    $rawMsg = Build-RawMimeMessage $from $toCsv $ccCsv $subject $plainBody $htmlBody

    # Dot-stuffing (robusto contro null)
    $rawLines = $rawMsg -split "`r`n"
    if ($null -eq $rawLines) { $rawLines = @() }
    foreach ($l in $rawLines) {
        $line = if ($null -eq $l) { '' } else { [string]$l }
        if ($line.StartsWith(".")) { Send-SmtpLine $writer ("." + $line) } else { Send-SmtpLine $writer $line }
    }
    Send-SmtpLine $writer "."
    $resp = Read-SmtpResponse $reader
    Expect-Code $resp @(250) "DATA end"

    Send-SmtpLine $writer "QUIT" | Out-Null
    try { [void](Read-SmtpResponse $reader) } catch { }

    try { $ssl.Close() } catch { }
    try { $tcp.Close() } catch { }
}

function Send-EmailNotification($cfg, [string]$subject, [string]$plainBody, [string]$htmlBody) {
    if (-not $cfg.Email.Enabled) { return }

    $smtpServer = $cfg.Email.SmtpHost
    $smtpPort   = Safe-Int $cfg.Email.SmtpPort 25
    $useSsl      = [bool]$cfg.Email.UseSsl
    $useAuth     = [bool]$cfg.Email.UseAuth

    if ([string]::IsNullOrWhiteSpace($smtpServer)) { throw "SMTP host non configurato." }
    if ([string]::IsNullOrWhiteSpace($cfg.Email.From)) { throw "From mancante." }
    if ([string]::IsNullOrWhiteSpace($cfg.Email.To)) { throw "To mancante." }

    $from = $cfg.Email.From.Trim()
    $toList = Parse-AddressList $cfg.Email.To
    $ccList = Parse-AddressList $cfg.Email.Cc

    $username = $cfg.Email.Username
    $password = Unprotect-Secret $cfg.Email.PasswordProtected

    # Implicit TLS (porta 465) NON è gestita bene da SmtpClient su molte installazioni (.NET Framework).
    # Qui usiamo un client SMTP minimale via SslStream.
    $implicitTlsErr = $null
    if ($useSsl -and $smtpPort -eq 465) {
        try {
        Send-Email-ImplicitTLS `
            -smtpServer $smtpServer `
            -smtpPort $smtpPort `
            -useAuth $useAuth `
            -username $username `
            -password $password `
            -from $from `
            -toList $toList `
            -ccList $ccList `
            -subject $subject `
            -plainBody $plainBody `
            -htmlBody $htmlBody
            return
        } catch {
            # Fallback a SmtpClient: alcuni provider/stack funzionano meglio così.
            $implicitTlsErr = $_.Exception.Message
        }
    }

    # STARTTLS / porta 587 (o 25/relay): SmtpClient va bene
    $msg = New-Object System.Net.Mail.MailMessage
    $msg.From = $from

    foreach ($t in $toList) { $msg.To.Add($t) }
    foreach ($c in $ccList) { $msg.CC.Add($c) }

    $msg.Subject = $subject
    $msg.Body = $plainBody
    $msg.IsBodyHtml = $false

    $altPlain = [System.Net.Mail.AlternateView]::CreateAlternateViewFromString($plainBody, [System.Text.Encoding]::UTF8, 'text/plain')
    $altHtml  = [System.Net.Mail.AlternateView]::CreateAlternateViewFromString($htmlBody, [System.Text.Encoding]::UTF8, 'text/html')
    $msg.AlternateViews.Add($altPlain)
    $msg.AlternateViews.Add($altHtml)

    $client = New-Object System.Net.Mail.SmtpClient($smtpServer, $smtpPort)
    $client.Timeout = 20000
    $client.DeliveryMethod = [System.Net.Mail.SmtpDeliveryMethod]::Network
    $client.UseDefaultCredentials = $false
    $client.EnableSsl = $useSsl

    if ($useAuth) {
        if ([string]::IsNullOrWhiteSpace($username) -or [string]::IsNullOrWhiteSpace($password)) {
            throw "SMTP login attivo ma Username/Password mancanti."
        }
        $client.Credentials = New-Object System.Net.NetworkCredential($username, $password)
    }

    try {
        $client.Send($msg)
    } catch {
        # Mostra dettagli utili per capire il vero motivo (auth/ssl/relay/etc.)
        $e = $_.Exception
        $inner = if ($e.InnerException) { $e.InnerException.Message } else { "" }
        $extra = ""
        try {
            if ($e -is [System.Net.Mail.SmtpException]) { $extra = " (StatusCode: $($e.StatusCode))" }
        } catch {}
        $imp = ""
        try { if ($implicitTlsErr) { $imp = " | ImplicitTLS: $implicitTlsErr" } } catch { }
        throw ("Errore invio mail: {0}{1}{2}{3}" -f $e.Message, $extra, (if ($inner) { " | Inner: $inner" } else { "" }), $imp)
    }
}

# [BOOKMARK:DISCORD]
function Send-DiscordNotification($cfg, [string]$status, [string]$backupName, [string]$shortMsg, [string]$reasonTag) {
    if (-not $cfg.Discord.Enabled) { return }
    $wh = Unprotect-Secret $cfg.Discord.WebhookProtected
    if ([string]::IsNullOrWhiteSpace($wh)) { throw "Webhook Discord mancante." }

    # Colore e icona in base allo stato
    $color = switch ($status) {
        'FAIL'    { 15158332 }  # rosso    #E74C3C
        'MISSING' { 15105570 }  # arancio  #E67E22
        'OK'      { 3066993  }  # verde    #2ECC71
        default   { 9807270  }  # grigio   #95A5A6
    }
    $icon = switch ($status) {
        'FAIL'    { 'FAIL' }
        'MISSING' { 'MANCANTE' }
        'OK'      { 'OK' }
        default   { $status }
    }

    $now = Get-Date -Format 'dd/MM/yyyy HH:mm'
    $prefix = ([string]$cfg.Email.SubjectPrefix).Trim()
    $title = if (-not [string]::IsNullOrWhiteSpace($prefix)) { "$prefix $backupName" } else { $backupName }

    $embed = @{
        title       = "$icon -- $title"
        description = $shortMsg
        color       = $color
        footer      = @{ text = "Motivo: $reasonTag  |  $now" }
    }
    $payload = @{ embeds = @($embed) } | ConvertTo-Json -Depth 6
    Invoke-RestMethod -Uri $wh -Method Post -Body $payload -ContentType "application/json; charset=utf-8"
}

# [BOOKMARK:NOTIFY]
function Notify($cfg, $state, [string]$reasonTag, [switch]$Force) {
    # Subject richiesto: SOLO nome backup (BackupName)
    # Usa SubjectPrefix se configurato (es. '[BACKUP]'), altrimenti solo BackupName
    $prefix = ([string]$cfg.Email.SubjectPrefix).Trim()
    $subject = if (-not [string]::IsNullOrWhiteSpace($prefix)) { "$prefix $($cfg.BackupName)" } else { [string]$cfg.BackupName }

    # Tronca il messaggio a 120 caratteri per notifiche (il dettaglio completo e' nel log)
    $shortMsg = $state.Message
    if ($shortMsg.Length -gt 120) { $shortMsg = $shortMsg.Substring(0, 117) + '...' }

    $plain = @"
Motivo: $reasonTag
Stato:  $($state.Status)
Dettaglio: $shortMsg
Ora: $(Get-Date -Format 'dd/MM/yyyy HH:mm')
"@

    $html = @"
<html><body style='font-family:Segoe UI, Arial; font-size:14px;'>
<h3 style='margin:0;'>$subject</h3>
<p style='margin:10px 0 0 0;'><b>$($state.Status)</b> -- $shortMsg</p>
<p style='color:#888; font-size:12px; margin-top:14px;'>$reasonTag  |  $(Get-Date -Format 'dd/MM/yyyy HH:mm')</p>
</body></html>
"@

    $shouldSend = $Force -or ($state.Status -ne 'OK') -or [bool]$cfg.SendOnSuccessEvent -or ($cfg.DailyNotifyMode -eq 'Always')
    if (-not $shouldSend) { return }

    if ($cfg.NotifyMode -in @('Email','Both')) {
        Send-EmailNotification -cfg $cfg -subject $subject -plainBody $plain -htmlBody $html
    }
    if ($cfg.NotifyMode -in @('Discord','Both')) {
        Send-DiscordNotification -cfg $cfg -status $state.Status -backupName $cfg.BackupName -shortMsg $shortMsg -reasonTag $reasonTag
    }
}

# [BOOKMARK:VALIDATION]
function Validate-ConfigOrThrow($c) {
    if ([string]::IsNullOrWhiteSpace($c.BackupName)) { throw "BackupName mancante." }
    if ([string]::IsNullOrWhiteSpace($c.NotifyMode)) { throw "Seleziona Notifica." }

    # BackupMode
    $c.BackupMode = Normalize-BackupMode ([string]$c.BackupMode)

    if ([bool]$c.DailyCheckEnabled) {
        $c.DailyCheckTime = Normalize-ScheduleTimeLoose $c.DailyCheckTime '09:30'
        if ([int]$c.MissingIfSuccessOlderThanHours -lt 1) { throw "Soglia ore non valida." }
    }

    $c.ScheduleFrequency = ([string]$c.ScheduleFrequency).Trim()
    if ($c.ScheduleFrequency -notin @('Daily','Weekly','Monthly')) {
        $c.ScheduleFrequency = 'Daily'
    }

    if ($c.NotifyMode -in @('Email','Both')) {
        if ([string]::IsNullOrWhiteSpace($c.Email.SmtpHost)) { throw "SMTP Host mancante." }
        $p = [int]$c.Email.SmtpPort
        if ($p -lt 1 -or $p -gt 65535) { throw "Porta SMTP non valida." }
        if ([string]::IsNullOrWhiteSpace($c.Email.From)) { throw "From mancante." }
        if ([string]::IsNullOrWhiteSpace($c.Email.To)) { throw "To mancante." }

        if ([bool]$c.Email.UseAuth) {
            if ([string]::IsNullOrWhiteSpace($c.Email.Username)) { throw "SMTP login: Username mancante." }
            $pwd = Unprotect-Secret $c.Email.PasswordProtected
            if ([string]::IsNullOrWhiteSpace($pwd)) { throw "SMTP login: Password mancante (inseriscila nel campo Password)." }
        }
    }

    if ($c.NotifyMode -in @('Discord','Both')) {
        if (-not [bool]$c.Discord.Enabled) { throw "Hai scelto Discord/Both ma Discord è disabilitato." }
        $wh = Unprotect-Secret $c.Discord.WebhookProtected
        if ([string]::IsNullOrWhiteSpace($wh)) { throw "Webhook Discord mancante (incollalo e salva)." }
    }
}

# [BOOKMARK:SETUP_UI]

# [BOOKMARK:SETUP_FORM]
function Run-SetupForm {
    $cfg = Load-Config
    # Ensure secret key exists early
    [void](Get-OrCreate-SecretKeyBytes)

    Add-Type -AssemblyName System.Windows.Forms
    Add-Type -AssemblyName System.Drawing

    # $script:dirty viene azzerato DOPO il popolamento dei controlli
    # (vedi sotto, prima di ShowDialog) per evitare che i TextChanged/CheckedChanged
    # scattino durante il popolamento e marchino il form come "modificato" da solo.
    $script:dirty = $false
    function Mark-Dirty { $script:dirty = $true }

    $ui = @{
        FormWidth   = 848
        FormHeight  = 730
        MinWidth    = 820
        MinHeight   = 700
        BottomH     = 50
        SideMargin  = 16
        GroupWidth  = 802
        LabelW      = 236
        InputX      = 258
        InputW      = 518
        GapY        = 4
    }

    $form = New-Object System.Windows.Forms.Form
    $form.Text = "Backup Monitor v$($script:BKP_VERSION) - Setup"
    $form.Width = $ui.FormWidth
    $form.Height = $ui.FormHeight
    $form.StartPosition = 'CenterScreen'
    $form.Font = New-Object System.Drawing.Font('Segoe UI', 9)
    $form.AutoScaleMode = [System.Windows.Forms.AutoScaleMode]::Font

    # Allow window resize/maximize
    $form.FormBorderStyle = [System.Windows.Forms.FormBorderStyle]::FixedDialog
    $form.MaximizeBox = $false
    $form.MinimizeBox = $true
    $form.MinimumSize = New-Object System.Drawing.Size($ui.MinWidth, $ui.MinHeight)

    $bottom = New-Object System.Windows.Forms.Panel
    $bottom.Dock = 'Bottom'
    $bottom.Height = $ui.BottomH
    $bottom.Padding = New-Object System.Windows.Forms.Padding(16,8,16,6)
    $form.Controls.Add($bottom)

    $content = New-Object System.Windows.Forms.Panel
    $content.Dock = 'Fill'
    $content.AutoScroll = $false
    $content.Padding = New-Object System.Windows.Forms.Padding(16,10,16,8)
    $form.Controls.Add($content)

    $SideMargin = $ui.SideMargin
    $LabelW = $ui.LabelW
    $InputX = $ui.InputX
    $InputW = $ui.InputW

    function Add-Label($parent, $text, $x, $y, $w) {
        $l = New-Object System.Windows.Forms.Label
        $l.Text = $text
        $l.Left = $x
        $l.Top = $y + 4
        $l.Width = $w
        $parent.Controls.Add($l)
        return $l
    }

    function Add-TextBox($parent, $x, $y, $w) {
        $t = New-Object System.Windows.Forms.TextBox
        $t.Left = $x
        $t.Top = $y
        $t.Width = $w
        $t.Anchor = 'Top,Left,Right'
        $t.Add_TextChanged({ Mark-Dirty })
        $parent.Controls.Add($t)
        return $t
    }

    function Add-CheckBox($parent, $text, $x, $y) {
        $c = New-Object System.Windows.Forms.CheckBox
        $c.Text = $text
        $c.Left = $x
        $c.Top = $y
        $c.AutoSize = $true
        $c.Add_CheckedChanged({ Mark-Dirty })
        $parent.Controls.Add($c)
        return $c
    }

    function Add-Combo($parent, $x, $y, $w, $items) {
        $cb = New-Object System.Windows.Forms.ComboBox
        $cb.Left = $x
        $cb.Top = $y
        $cb.Width = $w
        $cb.DropDownStyle = 'DropDownList'
        [void]$cb.Items.AddRange($items)
        $cb.Add_SelectedIndexChanged({ Mark-Dirty })
        $parent.Controls.Add($cb)
        return $cb
    }

    function Add-TimePicker($parent, $x, $y, $w) {
        $tp = New-Object System.Windows.Forms.DateTimePicker
        $tp.Left = $x
        $tp.Top = $y
        $tp.Width = $w
        $tp.Format = [System.Windows.Forms.DateTimePickerFormat]::Custom
        $tp.CustomFormat = 'HH:mm'
        $tp.ShowUpDown = $true
        $tp.Add_ValueChanged({ Mark-Dirty })
        $parent.Controls.Add($tp)
        return $tp
    }

    function Get-UiTimeParts([string]$value) {
        $raw = ([string]$value).Trim()
        if ([string]::IsNullOrWhiteSpace($raw)) {
            return @{ Hour = 9; Minute = 30 }
        }

        if ($raw -match '^(\d{1,2}):(\d{2})$') {
            $h = [int]$matches[1]
            $m = [int]$matches[2]
            if ($h -lt 0) { $h = 0 }
            if ($h -gt 23) { $h = 23 }
            if ($m -lt 0) { $m = 0 }
            if ($m -gt 59) { $m = 59 }
            return @{ Hour = $h; Minute = $m }
        }

        return @{ Hour = 9; Minute = 30 }
    }

    function Set-TimePickerValue($picker, [string]$value) {
        $parts = Get-UiTimeParts $value
        $picker.Value = (Get-Date -Hour $parts.Hour -Minute $parts.Minute -Second 0)
    }

    function Get-TimePickerValue($picker) {
        return $picker.Value.ToString('HH:mm')
    }

    function Show-Err([string]$msg) {
        [System.Windows.Forms.MessageBox]::Show($msg,'Errore','OK','Error') | Out-Null
    }

    $info = New-Object System.Windows.Forms.Label
    $info.AutoSize = $false
    $info.Width = $ui.GroupWidth - 130
    $info.Height = 22
    $info.AutoEllipsis = $true
    $info.Text = "Config: $ConfigPath   |   Key: $SecretKeyPath"
    $info.ForeColor = [System.Drawing.Color]::FromArgb(90,90,90)
    $info.Left = $SideMargin
    $info.Top = 6
    $content.Controls.Add($info)

    $btnOpenFolder = New-Object System.Windows.Forms.Button
    $btnOpenFolder.Text = "Apri cartella"
    $btnOpenFolder.Width = 108
    $btnOpenFolder.Height = 24
    $btnOpenFolder.Left = $SideMargin + $ui.GroupWidth - $btnOpenFolder.Width
    $btnOpenFolder.Top = 2
    $btnOpenFolder.Anchor = 'Top,Right'
    $btnOpenFolder.Add_Click({
        try {
            Start-Process -FilePath "explorer.exe" -ArgumentList $ConfigDir
        } catch {
            Show-Err "Impossibile aprire la cartella: $ConfigDir`n`n$($_.Exception.Message)"
        }
    })
    $content.Controls.Add($btnOpenFolder)

