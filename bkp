$ScriptPath = Get-SelfScriptPath

# FIX: usa ProgramData come path condiviso tra utente e task SYSTEM.
# LocalAppData e per-user: quando il task gira come SYSTEM usa un profilo
# diverso (C:\Windows\System32\Config\SystemProfile\...) e non trova
# config.json ne secret.key dell'utente. ProgramData e accessibile da tutti.
$ConfigDirPrimary  = Join-Path $env:ProgramData 'BackupMonitor'
$ConfigDirFallback = Join-Path $env:LOCALAPPDATA 'BackupMonitor'

function Ensure-Dir([string]$Path) {
    if (-not (Test-Path $Path)) { New-Item -ItemType Directory -Path $Path -Force | Out-Null }
}

function Test-WriteAccess([string]$Dir) {
    try {
        Ensure-Dir $Dir
        $tmp = Join-Path $Dir (".write_test_{0}.tmp" -f $PID)
        "ok" | Set-Content -Path $tmp -Encoding UTF8 -Force
        Remove-Item -Path $tmp -Force -ErrorAction SilentlyContinue
        return $true
    } catch {
        return $false
    }
}

function Initialize-ConfigPaths {
    # Usa ProgramData se accessibile in scrittura (accessibile anche da SYSTEM).
    # Fallback su LocalAppData solo se ProgramData non e scrivibile.
    # Migrazione automatica: se esiste config in LocalAppData ma non in ProgramData,
    # la copia una volta sola cosi le installazioni esistenti non perdono la config.
    $chosen = if (Test-WriteAccess $ConfigDirPrimary) { $ConfigDirPrimary } else { $ConfigDirFallback }
    Ensure-Dir $chosen

    # Se finisce su LocalAppData, i task SYSTEM useranno un profilo diverso e
    # non troveranno config/secret. Lo segnaliamo con un warning visibile.
    if ($chosen -eq $ConfigDirFallback -and $chosen -ne $ConfigDirPrimary) {
        Write-Warning "ATTENZIONE: impossibile scrivere in ProgramData. Config salvata in LocalAppData."
        Write-Warning "I task automatici (SYSTEM) non troveranno la configurazione. Esegui lo script con privilegi elevati per usare ProgramData."
    }

    # Migrazione da LocalAppData a ProgramData (eseguita una volta sola)
    if ($chosen -eq $ConfigDirPrimary -and $chosen -ne $ConfigDirFallback) {
        foreach ($fileName in @('config.json', 'secret.key', 'runtime_state.json')) {
            $src = Join-Path $ConfigDirFallback $fileName
            $dst = Join-Path $chosen $fileName
            if ((Test-Path $src) -and -not (Test-Path $dst)) {
                try { Copy-Item $src $dst -Force } catch { }
            }
        }
    }

    $script:ConfigDir     = $chosen
    $script:ConfigPath    = Join-Path $script:ConfigDir 'config.json'
    $script:SecretKeyPath = Join-Path $script:ConfigDir 'secret.key'
}

Initialize-ConfigPaths
$script:RuntimeStatePath = Join-Path $script:ConfigDir 'runtime_state.json'
$script:DiagLogPath = Join-Path $script:ConfigDir 'diag.log'
# [BOOKMARK:PSOBJECT_HELPERS]
function Set-OrAddProp([object]$obj, [string]$name, $value) {
    if ($null -eq $obj) { return }
    if ($obj.PSObject.Properties.Match($name).Count -eq 0) {
        $obj | Add-Member -NotePropertyName $name -NotePropertyValue $value -Force
    } else {
        $obj.$name = $value
    }
}

function Ensure-SubObject([object]$obj, [string]$name, [object]$defaultValue) {
    if ($null -eq $obj) { return }
    if ($obj.PSObject.Properties.Match($name).Count -eq 0 -or $null -eq $obj.$name) {
        $obj | Add-Member -NotePropertyName $name -NotePropertyValue $defaultValue -Force
    }
}

# [BOOKMARK:SECRETS_AES]
function Set-FileAclToSystemAndAdmins([string]$path) {
    try {
        $acl = Get-Acl -Path $path
        $sidSystem = New-Object System.Security.Principal.SecurityIdentifier('S-1-5-18')      # LocalSystem
        $sidAdmins = New-Object System.Security.Principal.SecurityIdentifier('S-1-5-32-544')  # Builtin Administrators

        $ruleSystem = New-Object System.Security.AccessControl.FileSystemAccessRule($sidSystem,'FullControl','Allow')
        $ruleAdmins = New-Object System.Security.AccessControl.FileSystemAccessRule($sidAdmins,'FullControl','Allow')

        $acl.SetAccessRuleProtection($true, $false) | Out-Null
        $acl.Access | ForEach-Object { $acl.RemoveAccessRule($_) } | Out-Null

        $acl.AddAccessRule($ruleSystem) | Out-Null
        $acl.AddAccessRule($ruleAdmins) | Out-Null

        # Importante: consenti anche all'utente corrente di leggere/scrivere la chiave,
        # altrimenti dalla UI il file secret.key viene creato ma subito reso illeggibile,
        # e la password SMTP/Webhook risultano "mancanti" anche se appena inserite.
        try {
            $currentIdentity = [System.Security.Principal.WindowsIdentity]::GetCurrent()
            if ($currentIdentity -and $currentIdentity.User) {
                $ruleCurrent = New-Object System.Security.AccessControl.FileSystemAccessRule($currentIdentity.User,'FullControl','Allow')
                $acl.AddAccessRule($ruleCurrent) | Out-Null
            }
        } catch { }

        Set-Acl -Path $path -AclObject $acl
    } catch { }
}

function Get-OrCreate-SecretKeyBytes {
    Ensure-Dir $ConfigDir

    if (-not (Test-Path $SecretKeyPath)) {
        $key = New-Object byte[] 32
        [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($key)
        [System.IO.File]::WriteAllBytes($SecretKeyPath, $key)
        Set-FileAclToSystemAndAdmins $SecretKeyPath
        return $key
    }

    try {
        $key = [System.IO.File]::ReadAllBytes($SecretKeyPath)
        if (-not $key -or $key.Length -lt 32) {
            $key = New-Object byte[] 32
            [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($key)
            [System.IO.File]::WriteAllBytes($SecretKeyPath, $key)
            Set-FileAclToSystemAndAdmins $SecretKeyPath
        } else {
            # FIX: ripara le ACL anche su chiavi esistenti (installazioni pregresse
            # potrebbero avere permessi sbagliati che impediscono lettura a SYSTEM).
            try { Set-FileAclToSystemAndAdmins $SecretKeyPath } catch { }
        }
        return $key
    } catch {
        throw "Impossibile leggere la chiave segreta: $SecretKeyPath. Esegui lo script con gli stessi permessi con cui l'hai creato, oppure elimina secret.key e ricrealo con questa versione corretta. Dettaglio: $($_.Exception.Message)"
    }
}

function Derive-Key([byte[]]$baseKey, [byte]$tag) {
    $data = New-Object byte[] ($baseKey.Length + 1)
    [Array]::Copy($baseKey, 0, $data, 0, $baseKey.Length)
    $data[$data.Length - 1] = $tag
    ([System.Security.Cryptography.SHA256]::Create()).ComputeHash($data) # 32 bytes
}

function Protect-Secret([string]$PlainText) {
    if ([string]::IsNullOrWhiteSpace($PlainText)) { return $null }

    $baseKey = Get-OrCreate-SecretKeyBytes
    $encKey  = Derive-Key $baseKey 0x01
    $macKey  = Derive-Key $baseKey 0x02

    $iv = New-Object byte[] 16
    [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($iv)

    $aes = [System.Security.Cryptography.Aes]::Create()
    $aes.Mode = [System.Security.Cryptography.CipherMode]::CBC
    $aes.Padding = [System.Security.Cryptography.PaddingMode]::PKCS7
    $aes.Key = $encKey
    $aes.IV  = $iv

    $plainBytes = [System.Text.Encoding]::UTF8.GetBytes($PlainText)

    $ms = New-Object System.IO.MemoryStream
    $cs = New-Object System.Security.Cryptography.CryptoStream($ms, $aes.CreateEncryptor(), [System.Security.Cryptography.CryptoStreamMode]::Write)
    $cs.Write($plainBytes, 0, $plainBytes.Length)
    $cs.FlushFinalBlock()
    $cs.Close()
    $cipher = $ms.ToArray()
    $ms.Dispose()

    $toMac = New-Object byte[] ($iv.Length + $cipher.Length)
    [Array]::Copy($iv, 0, $toMac, 0, $iv.Length)
    [Array]::Copy($cipher, 0, $toMac, $iv.Length, $cipher.Length)

    $hmac = New-Object System.Security.Cryptography.HMACSHA256 -ArgumentList (, $macKey)
    $tagBytes = $hmac.ComputeHash($toMac)

    $payload = New-Object byte[] ($toMac.Length + $tagBytes.Length)
    [Array]::Copy($toMac, 0, $payload, 0, $toMac.Length)
    [Array]::Copy($tagBytes, 0, $payload, $toMac.Length, $tagBytes.Length)

    return [Convert]::ToBase64String($payload)
}

function Unprotect-Secret([string]$Base64) {
    if ([string]::IsNullOrWhiteSpace($Base64)) { return $null }

    $payload = $null
    try { $payload = [Convert]::FromBase64String($Base64) } catch { return $null }
    if (-not $payload -or $payload.Length -lt (16 + 32)) { return $null }

    $baseKey = Get-OrCreate-SecretKeyBytes
    $encKey  = Derive-Key $baseKey 0x01
    $macKey  = Derive-Key $baseKey 0x02

    $tagLen = 32
    $dataLen = $payload.Length - $tagLen

    $data = New-Object byte[] $dataLen
    $tagBytes = New-Object byte[] $tagLen
    [Array]::Copy($payload, 0, $data, 0, $dataLen)
    [Array]::Copy($payload, $dataLen, $tagBytes, 0, $tagLen)

    $hmac = New-Object System.Security.Cryptography.HMACSHA256 -ArgumentList (, $macKey)
    $calc = $hmac.ComputeHash($data)

    for ($i=0; $i -lt $calc.Length; $i++) {
        if ($calc[$i] -ne $tagBytes[$i]) { return $null }
    }

    $iv = New-Object byte[] 16
    [Array]::Copy($data, 0, $iv, 0, 16)
    $cipherLen = $dataLen - 16
    if ($cipherLen -le 0) { return $null }
    $cipher = New-Object byte[] $cipherLen
    [Array]::Copy($data, 16, $cipher, 0, $cipherLen)

    try {
        $aes = [System.Security.Cryptography.Aes]::Create()
        $aes.Mode = [System.Security.Cryptography.CipherMode]::CBC
        $aes.Padding = [System.Security.Cryptography.PaddingMode]::PKCS7
        $aes.Key = $encKey
        $aes.IV  = $iv

        $ms = New-Object System.IO.MemoryStream
        $cs = New-Object System.Security.Cryptography.CryptoStream($ms, $aes.CreateDecryptor(), [System.Security.Cryptography.CryptoStreamMode]::Write)
        $cs.Write($cipher, 0, $cipher.Length)
        $cs.FlushFinalBlock()
        $cs.Close()
        $plain = $ms.ToArray()
        $ms.Dispose()

        return [System.Text.Encoding]::UTF8.GetString($plain)
    } catch {
        return $null
    }
}

# [BOOKMARK:TIME_HELPERS]
function Normalize-TimeString([string]$input) {
    if ([string]::IsNullOrWhiteSpace($input)) { return $null }

    $raw = ([string]$input).Trim()

    if ($raw -match '^\s*(\d{1,2})\s*:\s*(\d{1,2})\s*$') {
        $hour = [int]$Matches[1]
        $minute = [int]$Matches[2]
    } else {
        $digits = ($raw -replace '[^\d]', '')
        switch ($digits.Length) {
            4 {
                $hour = [int]$digits.Substring(0,2)
                $minute = [int]$digits.Substring(2,2)
            }
            3 {
                $hour = [int]$digits.Substring(0,1)
                $minute = [int]$digits.Substring(1,2)
            }
            2 {
                $hour = [int]$digits
                $minute = 0
            }
            1 {
                $hour = [int]$digits
                $minute = 0
            }
            default { return $null }
        }
    }

    if ($hour -lt 0 -or $hour -gt 23) { return $null }
    if ($minute -lt 0 -or $minute -gt 59) { return $null }

    return ('{0:D2}:{1:D2}' -f $hour, $minute)
}

function Clean-Time([string]$t) {
    $n = Normalize-TimeString $t
    if ($null -eq $n) { return '' }
    return $n
}

function Validate-Time([string]$t) {
    return ($null -ne (Normalize-TimeString $t))
}

function Normalize-ScheduleTimeLoose([object]$value, [string]$fallback = '09:30') {
    $raw = ''
    try { $raw = [string]$value } catch { $raw = '' }

    $raw = $raw.Trim().Trim('"').Trim("'")
    if ([string]::IsNullOrWhiteSpace($raw)) { return $fallback }

    $sanitized = ($raw -replace '[^0-9:]', '')
    if ([string]::IsNullOrWhiteSpace($sanitized)) { return $fallback }

    $hour = 0
    $minute = 0

    if ($sanitized -match '^(?<h>\d{1,2}):(?<m>\d{1,2})$') {
        $hour = [int]$Matches['h']
        $minute = [int]$Matches['m']
    } else {
        $digits = ($sanitized -replace ':', '')
        switch ($digits.Length) {
            4 {
                $hour = [int]$digits.Substring(0,2)
                $minute = [int]$digits.Substring(2,2)
            }
            3 {
                $hour = [int]$digits.Substring(0,1)
                $minute = [int]$digits.Substring(1,2)
            }
            2 {
                $hour = [int]$digits
                $minute = 0
            }
            1 {
                $hour = [int]$digits
                $minute = 0
            }
            default {
                return $fallback
            }
        }
    }

    if ($hour -lt 0 -or $hour -gt 23) { return $fallback }
    if ($minute -lt 0 -or $minute -gt 59) { return $fallback }

    return ('{0:D2}:{1:D2}' -f $hour, $minute)
}

