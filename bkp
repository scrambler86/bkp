# ==================================================================================================
#  Backup Monitor (Email + Discord) - Failure/Missing only (configurable)
#  v5.11:
#    - Cooldown notifiche FAIL: checkbox nel Setup (30 min dopo prima notifica, silenzio)
#    - Fix sezione Discord nel Setup (altezza corretta)
#  v5.10:
#    - Messaggio notifica troncato a 120 caratteri (era troppo lungo)
#    - UI: label stato allargata, testo non esce piu dal riquadro
#    - UI: "Esegui Check ora" tronca il testo a 100 caratteri
#  v5.9:
#    - FIX ENCODING: rimossi caratteri em-dash che causavano ParseError su PowerShell
#    - LOG DEBUG: logging dettagliato su diag.log (BackupMode, log trovati, classificazione eventi, errori)
#    - UI: pulsante 'Apri Log Debug' apre diag.log in Notepad
#    - UI: pulsante 'Esegui Check ora' mostra stato backup in tempo reale senza attendere il task
#  v5.8:
#    - FIX EVENT: trigger registrato su FileHistory-Core/WHC (il log reale su Win10/11)
#      => finalmente arrivano notifiche immediate per eventi FileHistory
#    - FIX EVENT: Get-TriggerEventLogNames include FileHistory-Core/WHC in modalita FileHistory
#  v5.7 (precedente):
#    - Write-BkpScript ora copia se stesso invece di usare chunk Base64 statici
#      => ogni ricompilazione dell'exe aggiorna automaticamente bkp.ps1
#    - Versioning: schermata principale mostra avviso se bkp.ps1 installato
#      ha versione diversa da quella corrente dell'exe
#    - Setup: reinstalla i task automaticamente dopo ogni salvataggio config
#    - FIX v5.1: nessun falso allarme MISSING su PC nuovi senza backup mai eseguito
#    - DAILY fonte 1: Get-WBJob (motore WSB diretto, bypassa event log)
#                     funziona anche su stacco HD brutale o crash log
#    - DAILY fonte 2: Event Log multi-log (fallback automatico)
#                     usato su Win10/11, sistemi senza feature WB, File History
#    - EVENT trigger: mono-log stabile (invariato, RecordId affidabile)
#    - MonitorFileHistory: false di default, evita falsi positivi su WSB puro
#    - Pattern File History: solo stringhe specifiche, niente ambiguita
#  - Setup WinForms (scroll + bottoni fissi) con VALIDAZIONE + Salvataggio sicuro
#  - Config:   %ProgramData%\BackupMonitor\config.json  (condiviso utente+SYSTEM)
#  - Secrets:  AES + HMAC: %ProgramData%\BackupMonitor\secret.key
#              (NO ProtectedData -> compatibile anche dove ProtectedData manca)
#  - Compat:   Migrazione automatica config vecchi (aggiunge proprietà mancanti, no crash)
#  - Automazione (Task Scheduler):
#       1) EVENTO su EventID di fallimento  -> -RunEvent
#       2) CHECK GIORNALIERO (backup mancante) -> -RunDailyCheck
# ==================================================================================================

# [BOOKMARK:PARAMS]
[CmdletBinding()]
param(
    [switch]$RunEvent,
    [switch]$RunDailyCheck,

    [switch]$Setup,
    [switch]$Menu,

    [switch]$InstallAutomation,
    [switch]$RemoveAutomation,

    [switch]$TestEmail,
    [switch]$TestDiscord,
    [switch]$TestAll,

    [switch]$PrepareForCompile
)

# [BOOKMARK:ELEVATION]
# Auto-elevazione UAC: se non siamo Administrator, rilancia come Admin.
# Necessario per scrivere in ProgramData\ e per gestire i Task Scheduler.
# I switch -RunEvent e -RunDailyCheck girano gia come SYSTEM, non hanno bisogno di elevazione.
if (-not $RunEvent -and -not $RunDailyCheck) {
    $isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole(
        [Security.Principal.WindowsBuiltInRole]::Administrator)
    if (-not $isAdmin) {
        try {
            $selfPath = $MyInvocation.MyCommand.Path
            if ([string]::IsNullOrWhiteSpace($selfPath)) {
                $selfPath = [System.Diagnostics.Process]::GetCurrentProcess().MainModule.FileName
            }
            $ext = [System.IO.Path]::GetExtension($selfPath).ToLower()
            if ($ext -eq '.exe') {
                Start-Process -FilePath $selfPath -Verb RunAs
            } else {
                Start-Process -FilePath 'powershell.exe' `
                    -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$selfPath`"" `
                    -Verb RunAs
            }
        } catch {
            # Utente ha annullato UAC o errore: continua senza elevazione
        }
        exit
    }
}

